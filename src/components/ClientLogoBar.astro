---
---

<section class="relative bg-[#0f172a] border-b border-white/[0.06] py-10 sm:py-12 overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <p class="text-center text-white/30 text-xs font-semibold uppercase tracking-[0.2em] mb-8">Projetos entregues para</p>

    <div class="flex items-center justify-center gap-8 sm:gap-14 flex-wrap">
      <!-- Logo 1: Restaurant -->
      <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300 group" data-animate>
        <div class="w-9 h-9 rounded-lg bg-white/[0.06] group-hover:bg-white/[0.1] flex items-center justify-center transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>
          </svg>
        </div>
        <span class="text-sm font-medium hidden sm:block">Restaurante</span>
      </div>

      <!-- Logo 2: Clinic -->
      <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300 group" data-animate data-delay="1">
        <div class="w-9 h-9 rounded-lg bg-white/[0.06] group-hover:bg-white/[0.1] flex items-center justify-center transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8 2v4"/><path d="M16 2v4"/><path d="M12 11v4"/><path d="M10 13h4"/><rect width="18" height="18" x="3" y="4" rx="2"/>
          </svg>
        </div>
        <span class="text-sm font-medium hidden sm:block">Clínica</span>
      </div>

      <!-- Logo 3: Education -->
      <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300 group" data-animate data-delay="2">
        <div class="w-9 h-9 rounded-lg bg-white/[0.06] group-hover:bg-white/[0.1] flex items-center justify-center transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <span class="text-sm font-medium hidden sm:block">Educação</span>
      </div>

      <!-- Logo 4: Hair Salon -->
      <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300 group" data-animate data-delay="3">
        <div class="w-9 h-9 rounded-lg bg-white/[0.06] group-hover:bg-white/[0.1] flex items-center justify-center transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>
          </svg>
        </div>
        <span class="text-sm font-medium hidden sm:block">Cabeleireiro</span>
      </div>

      <!-- Logo 5: Shop -->
      <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300 group" data-animate data-delay="4">
        <div class="w-9 h-9 rounded-lg bg-white/[0.06] group-hover:bg-white/[0.1] flex items-center justify-center transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/>
          </svg>
        </div>
        <span class="text-sm font-medium hidden sm:block">Loja</span>
      </div>
    </div>
  </div>
</section>
