---
interface Props {
  waLink: string;
}
const { waLink } = Astro.props;
---

<section data-animate class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Porquê escolher-me</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif;">
        Agência vs. Francisco
      </h2>
      <p class="text-slate-500 text-lg mt-4 max-w-xl mx-auto">
        A mesma qualidade, sem os custos e tempos de espera de uma agência.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Agency column -->
      <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-slate-200 rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M3 21h18M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-400" style="font-family:'Sora',sans-serif;">Agência típica</h3>
        </div>
        <ul class="space-y-5">
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            <div><p class="font-semibold text-slate-700">€2.000 – €5.000</p><p class="text-slate-400 text-sm">Preço médio</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            <div><p class="font-semibold text-slate-700">4 – 8 semanas</p><p class="text-slate-400 text-sm">Prazo de entrega</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            <div><p class="font-semibold text-slate-700">Email, 48h de espera</p><p class="text-slate-400 text-sm">Forma de contacto</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            <div><p class="font-semibold text-slate-700">Júnior + manager + designer</p><p class="text-slate-400 text-sm">Quem faz o trabalho</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
            <div><p class="font-semibold text-slate-700">€50 – €100/mês</p><p class="text-slate-400 text-sm">Mensalidades obrigatórias</p></div>
          </li>
        </ul>
      </div>

      <!-- Francisco column -->
      <div class="bg-[#0f172a] rounded-2xl p-8 ring-2 ring-[#f97316] shadow-xl relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="bg-[#f97316] text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider shadow-lg">Melhor valor</span>
        </div>
        <div class="flex items-center gap-3 mb-8 mt-2">
          <div class="w-10 h-10 bg-[#f97316]/10 rounded-xl flex items-center justify-center">
            <span class="text-[#f97316] font-bold text-lg" style="font-family:'Sora',sans-serif;">FS</span>
          </div>
          <h3 class="text-lg font-bold text-white" style="font-family:'Sora',sans-serif;">Francisco Sousa</h3>
        </div>
        <ul class="space-y-5">
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div><p class="font-semibold text-white">€300 – €1.500</p><p class="text-white/40 text-sm">Preço fixo, sem surpresas</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div><p class="font-semibold text-white">3 – 5 dias úteis</p><p class="text-white/40 text-sm">Método Rápido</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div><p class="font-semibold text-white">WhatsApp, resposta em 2h</p><p class="text-white/40 text-sm">Contacto direto, sem intermediários</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div><p class="font-semibold text-white">A mesma pessoa do início ao fim</p><p class="text-white/40 text-sm">Sem hand-offs, sem confusão</p></div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div><p class="font-semibold text-white">€0/mês</p><p class="text-white/40 text-sm">Sem mensalidades, nunca</p></div>
          </li>
        </ul>
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 w-full inline-flex items-center justify-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-95 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-[#25d366]/25 hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar comigo agora
        </a>
      </div>
    </div>
  </div>
</section>
