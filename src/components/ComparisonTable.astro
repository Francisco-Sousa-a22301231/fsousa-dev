---
---

<section data-animate class="py-20 sm:py-24 bg-[#f8fafc]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Porquê escolher-me</p>
      <h2 class="font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif; font-size: var(--text-h1);">
        Agência vs. Francisco
      </h2>
      <p class="text-slate-500 text-lg mt-4 max-w-xl mx-auto">
        A mesma qualidade, sem os custos e tempos de espera de uma agência.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 comparison-grid">
      <!-- Agency column -->
      <div class="comparison-card-agency bg-white border border-slate-200 rounded-2xl p-8 relative" data-animate-left>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M3 21h18M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-400" style="font-family:'Sora',sans-serif;">Agência típica</h3>
        </div>
        <ul class="space-y-5">
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="m15 9-6 6M9 9l6 6"/></svg>
            </div>
            <div><p class="font-semibold text-slate-700 agency-price">€2.000 – €5.000</p><p class="text-slate-400 text-sm">Preço médio</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="m15 9-6 6M9 9l6 6"/></svg>
            </div>
            <div><p class="font-semibold text-slate-700">4 – 8 semanas</p><p class="text-slate-400 text-sm">Prazo de entrega</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="m15 9-6 6M9 9l6 6"/></svg>
            </div>
            <div><p class="font-semibold text-slate-700">Email, 48h de espera</p><p class="text-slate-400 text-sm">Forma de contacto</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="m15 9-6 6M9 9l6 6"/></svg>
            </div>
            <div><p class="font-semibold text-slate-700">Júnior + manager + designer</p><p class="text-slate-400 text-sm">Quem faz o trabalho</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="m15 9-6 6M9 9l6 6"/></svg>
            </div>
            <div><p class="font-semibold text-slate-700 agency-price">€50 – €100/mês</p><p class="text-slate-400 text-sm">Mensalidades obrigatórias</p></div>
          </li>
        </ul>
      </div>

      <!-- Francisco column -->
      <div class="comparison-card-francisco bg-[#0f172a] rounded-2xl p-8 ring-2 ring-[#f97316]/60 shadow-xl shadow-[#f97316]/5 relative" data-animate-right>
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="badge-shimmer bg-gradient-to-r from-[#f97316] to-[#f59e0b] text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg shadow-[#f97316]/25">Melhor valor</span>
        </div>
        <div class="flex items-center gap-3 mb-8 mt-2">
          <div class="w-10 h-10 bg-[#f97316]/10 rounded-xl flex items-center justify-center">
            <span class="text-[#f97316] font-bold text-lg" style="font-family:'Sora',sans-serif;">FS</span>
          </div>
          <h3 class="text-lg font-bold text-white" style="font-family:'Sora',sans-serif;">Francisco Sousa</h3>
        </div>
        <ul class="space-y-5">
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[#25d366]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><p class="font-semibold text-white">€300 – €1.500</p><p class="text-white/50 text-sm">Preço fixo, sem surpresas</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[#25d366]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><p class="font-semibold text-white">3 – 5 dias úteis</p><p class="text-white/50 text-sm">Método Rápido</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[#25d366]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><p class="font-semibold text-white">WhatsApp, resposta em 2h</p><p class="text-white/50 text-sm">Contacto direto, sem intermediários</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[#25d366]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><p class="font-semibold text-white">A mesma pessoa do início ao fim</p><p class="text-white/50 text-sm">Sem hand-offs, sem confusão</p></div>
          </li>
          <li class="comparison-item flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[#25d366]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><p class="font-semibold text-white">€0/mês</p><p class="text-white/50 text-sm">Sem mensalidades, nunca</p></div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Savings callout -->
    <div data-animate class="mt-8 text-center">
      <p class="text-slate-500 text-sm">
        Os meus clientes poupam em média <strong class="text-[#0f172a] font-semibold">€1.800</strong> em comparação com uma agência típica.
      </p>
    </div>
  </div>
</section>

<style>
  /* Strikethrough animation on agency prices */
  .agency-price {
    position: relative;
  }
  .agency-price::after {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 0;
    height: 2px;
    background: #ef4444;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .comparison-card-agency.is-visible .agency-price::after {
    width: 100%;
  }

  /* Badge shimmer effect */
  .badge-shimmer {
    position: relative;
    overflow: hidden;
  }
  .badge-shimmer::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: shimmer 3s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    40% { left: 100%; }
    100% { left: 100%; }
  }

  /* Comparison item stagger */
  .comparison-item {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }

  .comparison-card-agency.is-visible .comparison-item,
  .comparison-card-francisco.is-visible .comparison-item {
    opacity: 1;
    transform: translateY(0);
  }

  .comparison-card-agency.is-visible .comparison-item:nth-child(1),
  .comparison-card-francisco.is-visible .comparison-item:nth-child(1) { transition-delay: 0.1s; }
  .comparison-card-agency.is-visible .comparison-item:nth-child(2),
  .comparison-card-francisco.is-visible .comparison-item:nth-child(2) { transition-delay: 0.2s; }
  .comparison-card-agency.is-visible .comparison-item:nth-child(3),
  .comparison-card-francisco.is-visible .comparison-item:nth-child(3) { transition-delay: 0.3s; }
  .comparison-card-agency.is-visible .comparison-item:nth-child(4),
  .comparison-card-francisco.is-visible .comparison-item:nth-child(4) { transition-delay: 0.4s; }
  .comparison-card-agency.is-visible .comparison-item:nth-child(5),
  .comparison-card-francisco.is-visible .comparison-item:nth-child(5) { transition-delay: 0.5s; }

  @media (prefers-reduced-motion: reduce) {
    .comparison-item {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .agency-price::after {
      width: 100% !important;
      transition: none !important;
    }
    .badge-shimmer::after {
      animation: none !important;
    }
  }
</style>

<script>
  // Add is-visible class when cards enter viewport for CSS-driven item stagger
  const comparisonCards = document.querySelectorAll('.comparison-card-agency, .comparison-card-francisco');
  const compObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        compObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  comparisonCards.forEach((card) => compObserver.observe(card));
</script>
