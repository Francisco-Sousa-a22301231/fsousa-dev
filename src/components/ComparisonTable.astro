---
---

<section class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
        <div>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Porquê escolher-me</p>
          <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
            Agência vs.<br/>Francisco
          </h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-lg font-light max-w-md" data-animate>
          A mesma qualidade, sem os custos e tempos de espera de uma agência.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[var(--color-border)] max-w-[1000px]">
        <!-- Agency column -->
        <div class="comparison-card bg-[var(--color-bg)] p-8 sm:p-12" data-animate-left>
          <h3 class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-10">Agência típica</h3>
          <ul class="space-y-6">
            <li class="comparison-item">
              <p class="agency-price text-[var(--color-text-muted)] text-lg font-light">€2.000 – €5.000</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-1">Preço médio</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-text-muted)] text-lg font-light">4 – 8 semanas</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-1">Prazo de entrega</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-text-muted)] text-lg font-light">Email, 48h de espera</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-1">Forma de contacto</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-text-muted)] text-lg font-light">Júnior + manager + designer</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-1">Quem faz o trabalho</p>
            </li>
            <li class="comparison-item">
              <p class="agency-price text-[var(--color-text-muted)] text-lg font-light">€50 – €100/mês</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-1">Mensalidades obrigatórias</p>
            </li>
          </ul>
        </div>

        <!-- Francisco column -->
        <div class="comparison-card bg-[var(--color-text)] p-8 sm:p-12" data-animate-right>
          <div class="flex items-center justify-between mb-10">
            <h3 class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-bg)]/50">Francisco Sousa</h3>
            <span class="text-[var(--text-xs)] font-medium uppercase tracking-[0.1em] text-[var(--color-accent)] border border-[var(--color-accent)]/30 px-3 py-1 rounded-full">Melhor valor</span>
          </div>
          <ul class="space-y-6">
            <li class="comparison-item">
              <p class="text-[var(--color-bg)] text-lg font-light">€300 – €1.500</p>
              <p class="text-[var(--text-small)] text-[var(--color-bg)]/40 mt-1">Preço fixo, sem surpresas</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-bg)] text-lg font-light">3 – 5 dias úteis</p>
              <p class="text-[var(--text-small)] text-[var(--color-bg)]/40 mt-1">Método Rápido</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-bg)] text-lg font-light">WhatsApp, resposta em 2h</p>
              <p class="text-[var(--text-small)] text-[var(--color-bg)]/40 mt-1">Contacto direto</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-bg)] text-lg font-light">A mesma pessoa do início ao fim</p>
              <p class="text-[var(--text-small)] text-[var(--color-bg)]/40 mt-1">Sem hand-offs</p>
            </li>
            <li class="comparison-item">
              <p class="text-[var(--color-bg)] text-lg font-light">€0/mês</p>
              <p class="text-[var(--text-small)] text-[var(--color-bg)]/40 mt-1">Sem mensalidades, nunca</p>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mt-8" data-animate>
        Os meus clientes poupam em média €1.800 em comparação com uma agência típica.
      </p>
    </div>
  </div>
</section>

<script>
  const comparisonCards = document.querySelectorAll('.comparison-card');
  const compObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        compObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  comparisonCards.forEach((card) => compObserver.observe(card));
</script>
