---
---

<section class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
        <div>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Porquê escolher-me</p>
          <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
            Agência vs.<br/>Francisco
          </h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-lg font-light max-w-md" data-animate>
          A mesma qualidade, sem os custos e tempos de espera de uma agência.
        </p>
      </div>

      <!-- Comparison rows -->
      <div class="max-w-[1000px] space-y-4">
        <!-- Header row -->
        <div class="grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 px-6 sm:px-8 py-4" data-animate>
          <div></div>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] text-center">Agência</p>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-accent)] text-center">Francisco</p>
        </div>

        <!-- Price row -->
        <div class="comparison-row grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl px-6 sm:px-8 py-5" data-animate>
          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Preço médio</p>
          <p class="text-center text-[var(--color-text-muted)] font-light line-through decoration-[var(--color-text-subtle)]/40">€2.000 – €5.000</p>
          <p class="text-center text-[var(--color-text)] font-medium">€300 – €1.500</p>
        </div>

        <!-- Delivery row -->
        <div class="comparison-row grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl px-6 sm:px-8 py-5" data-animate>
          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Prazo de entrega</p>
          <p class="text-center text-[var(--color-text-muted)] font-light">4 – 8 semanas</p>
          <p class="text-center text-[var(--color-text)] font-medium">3 – 5 dias</p>
        </div>

        <!-- Contact row -->
        <div class="comparison-row grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl px-6 sm:px-8 py-5" data-animate>
          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Forma de contacto</p>
          <p class="text-center text-[var(--color-text-muted)] font-light">Email, 48h</p>
          <p class="text-center text-[var(--color-text)] font-medium">WhatsApp, 2h</p>
        </div>

        <!-- Who does the work row -->
        <div class="comparison-row grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl px-6 sm:px-8 py-5" data-animate>
          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Quem faz o trabalho</p>
          <p class="text-center text-[var(--color-text-muted)] font-light">Júnior + equipa</p>
          <p class="text-center text-[var(--color-text)] font-medium">Eu, do início ao fim</p>
        </div>

        <!-- Monthly fees row -->
        <div class="comparison-row grid grid-cols-[1fr_1fr_1fr] sm:grid-cols-[1.5fr_1fr_1fr] items-center gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-2xl px-6 sm:px-8 py-5" data-animate>
          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Mensalidades</p>
          <p class="text-center text-[var(--color-text-muted)] font-light">€50 – €100/mês</p>
          <div class="flex items-center justify-center gap-2">
            <span class="text-[var(--color-accent)]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <p class="text-[var(--color-text)] font-medium">€0/mês</p>
          </div>
        </div>

        <!-- Highlight card -->
        <div class="mt-8 bg-[var(--color-text)] rounded-2xl px-6 sm:px-8 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" data-animate>
          <div>
            <p class="text-[var(--color-bg)] font-light text-lg">Poupança média dos meus clientes</p>
            <p class="text-[var(--color-bg)]/50 text-[var(--text-small)] mt-1">Comparado com uma agência típica</p>
          </div>
          <span class="text-[var(--color-accent)] text-3xl sm:text-4xl font-light tracking-tight">€1.800+</span>
        </div>
      </div>
    </div>
  </div>
</section>
