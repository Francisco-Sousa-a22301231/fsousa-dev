---
interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<section class="relative py-20 sm:py-24 bg-[#0f172a] overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-[#f97316] opacity-[0.06] rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center" data-animate>
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-wider">
      <span class="w-2 h-2 bg-[#f97316] rounded-full animate-pulse"></span>
      Disponível agora
    </div>

    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-5 leading-tight" style="font-family:'Sora',sans-serif;">
      Pronto para ter <span class="hero-gradient-text">mais clientes?</span>
    </h2>

    <p class="text-white/60 text-lg sm:text-xl mb-10 max-w-xl mx-auto leading-relaxed">
      Peça um orçamento gratuito. Sem compromisso. Resposta em menos de 2 horas.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={waLink}
        target="_blank"
        rel="noopener noreferrer"
        class="magnetic-btn group inline-flex items-center justify-center gap-3 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-[0.97] text-white font-bold text-lg px-10 py-4 rounded-xl transition-all duration-200 shadow-lg shadow-[#25d366]/25 hover:shadow-xl hover:shadow-[#25d366]/30 hover:-translate-y-0.5 w-full sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-200 group-hover:scale-110">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir orçamento grátis
      </a>

      <a
        href="#contacto-form"
        class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 hover:bg-white/5 text-white/80 hover:text-white font-semibold text-lg px-10 py-4 rounded-xl transition-all duration-200 w-full sm:w-auto"
      >
        Enviar mensagem
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </a>
    </div>

    <p class="mt-6 text-sm text-white/30 flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      50% só quando estiver satisfeito · Sem contratos longos
    </p>
  </div>
</section>
