---
interface Props {
  gradientFrom: string;
  gradientTo: string;
  accentColor?: string;
  appName: string;
  tag: string;
  title: string;
  description: string;
  metrics: { label: string; value: string }[];
  tech: string[];
  link?: string;
  linkText?: string;
}

const {
  gradientFrom,
  gradientTo,
  accentColor = '#f97316',
  appName,
  tag,
  title,
  description,
  metrics,
  tech,
  link,
  linkText,
} = Astro.props;

// Derive a display URL from the link, or fabricate a plausible one
let displayUrl = `${appName.toLowerCase().replace(/\s+/g,'-')}.pt`;
if (link && link !== '#') {
  try { displayUrl = new URL(link).hostname; } catch (_) {}
}
---

<div
  class="portfolio-card group relative bg-white rounded-2xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-2xl transition-shadow duration-500"
  style="transform-style: preserve-3d; perspective: 1000px;"
>
  <!-- ── PREVIEW ZONE ── -->
  <div class="relative h-[270px] bg-[#eef0f5] overflow-visible">

    <!-- subtle grid texture -->
    <div class="absolute inset-0 opacity-[0.4]"
      style="background-image:radial-gradient(circle,#c8ccd8 1px,transparent 1px);background-size:18px 18px;"></div>

    <!-- ── BROWSER MOCKUP ── -->
    <div
      class="browser-window absolute left-5 right-[72px] top-6 bg-white rounded-xl shadow-xl border border-slate-200/80 overflow-hidden group-hover:-translate-y-1.5 transition-transform duration-500 z-10"
    >
      <!-- Chrome bar -->
      <div class="flex items-center gap-1.5 px-3 py-2 bg-[#e8ecf0] border-b border-slate-200">
        <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57] flex-shrink-0"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e] flex-shrink-0"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#28c840] flex-shrink-0"></span>
        <div class="flex-1 mx-2 bg-white rounded-[5px] px-2 py-[3px] flex items-center gap-1 border border-slate-200 min-w-0">
          <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="7" height="8" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span class="text-slate-400 text-[8px] font-mono truncate">{displayUrl}</span>
        </div>
        <div class="flex gap-1 ml-1 flex-shrink-0">
          <div class="w-3 h-3 rounded-sm border border-slate-200 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </div>
        </div>
      </div>

      <!-- Browser content (wireframe) -->
      <div class="relative overflow-hidden" style={`background:linear-gradient(160deg,${gradientFrom}10,${gradientTo}20)`}>
        <!-- Nav -->
        <div class="flex items-center justify-between px-3 py-2 border-b border-white/40">
          <div class="h-2.5 w-14 rounded-full" style={`background:${accentColor}cc`}></div>
          <div class="flex gap-2">
            <div class="h-1.5 w-7 rounded-full bg-slate-300/60"></div>
            <div class="h-1.5 w-7 rounded-full bg-slate-300/60"></div>
            <div class="h-1.5 w-7 rounded-full bg-slate-300/60"></div>
          </div>
          <div class="h-5 w-12 rounded-md" style={`background:${accentColor}dd`}></div>
        </div>
        <!-- Hero -->
        <div class="px-3 py-3">
          <div class="h-3 w-3/4 rounded-full bg-white/60 mb-2"></div>
          <div class="h-2 w-full rounded-full bg-white/30 mb-1.5"></div>
          <div class="h-2 w-5/6 rounded-full bg-white/30 mb-3"></div>
          <div class="flex gap-2">
            <div class="h-6 w-16 rounded-lg" style={`background:${accentColor}ee`}></div>
            <div class="h-6 w-14 rounded-lg bg-white/20 border border-white/30"></div>
          </div>
        </div>
        <!-- Cards row -->
        <div class="flex gap-2 px-3 pb-3">
          <div class="flex-1 h-10 rounded-lg bg-white/25 border border-white/20"></div>
          <div class="flex-1 h-10 rounded-lg bg-white/15 border border-white/15"></div>
          <div class="flex-1 h-10 rounded-lg bg-white/10 border border-white/10"></div>
        </div>
      </div>
    </div>

    <!-- ── PHONE MOCKUP ── -->
    <div
      class="phone-mockup absolute right-3 bottom-0 w-[66px] z-20 group-hover:-translate-y-2 group-hover:rotate-[4deg] transition-all duration-500"
      style="transform: rotate(6deg) translateY(10px);"
    >
      <!-- Phone shell -->
      <div class="relative bg-[#1c1c1e] rounded-[18px] border-[2.5px] border-[#3a3a3c] shadow-2xl overflow-hidden" style="aspect-ratio:9/19">
        <!-- Dynamic island / notch -->
        <div class="absolute top-[6px] left-1/2 -translate-x-1/2 w-8 h-[7px] bg-[#1c1c1e] rounded-full z-30"></div>
        <!-- Screen content -->
        <div class="absolute inset-0 pt-4 overflow-hidden" style={`background:linear-gradient(180deg,${gradientFrom},${gradientTo})`}>
          <!-- Status bar -->
          <div class="flex justify-between items-center px-2 mb-1">
            <div class="h-1 w-6 rounded-full bg-white/30"></div>
            <div class="flex gap-0.5">
              <div class="h-1 w-1 rounded-full bg-white/40"></div>
              <div class="h-1 w-2 rounded-full bg-white/40"></div>
            </div>
          </div>
          <!-- App header -->
          <div class="mx-2 mb-2 h-[22px] rounded-md bg-white/10 flex items-center px-2">
            <div class="h-1.5 w-10 rounded-full" style={`background:${accentColor}cc`}></div>
          </div>
          <!-- Content rows -->
          <div class="mx-2 space-y-1.5">
            <div class="h-[18px] rounded-md bg-white/15"></div>
            <div class="h-[18px] rounded-md bg-white/10"></div>
            <div class="h-[18px] rounded-md bg-white/10"></div>
            <div class="h-4 w-3/4 rounded-md" style={`background:${accentColor}50`}></div>
          </div>
          <!-- Bottom nav pill -->
          <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-8 h-1 bg-white/30 rounded-full"></div>
        </div>
      </div>
    </div>

    <!-- Category tag -->
    <div class="absolute top-3 left-4 z-30">
      <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-white/80 backdrop-blur-sm text-slate-600 border border-white/60 shadow-sm">{tag}</span>
    </div>

  </div><!-- /preview zone -->

  <!-- ── CARD BODY ── -->
  <div class="p-6">

    <!-- Title + description -->
    <h3 class="font-extrabold text-[#0f172a] text-[1.15rem] mb-1.5 leading-snug" style="font-family:'Sora Variable','Sora',sans-serif;">{title}</h3>
    <p class="text-slate-500 text-sm leading-relaxed mb-5">{description}</p>

    <!-- Metrics 2×2 grid -->
    <div class="grid grid-cols-2 gap-2.5 mb-5">
      {metrics.slice(0, 4).map((m) => (
        <div class="flex flex-col p-3 bg-[#f8fafc] rounded-xl border border-slate-100">
          <span class="font-extrabold text-[#0f172a] text-sm leading-tight" style="font-family:'Sora',sans-serif;">{m.value}</span>
          <span class="text-slate-400 text-[10px] mt-0.5 uppercase tracking-wide leading-tight">{m.label}</span>
        </div>
      ))}
    </div>

    <!-- Tech stack tags -->
    <div class="flex flex-wrap gap-1.5 mb-5">
      {tech.map((t) => (
        <span
          class="text-[11px] font-semibold px-2.5 py-[5px] rounded-full border"
          style={`background:${accentColor}10;color:${accentColor};border-color:${accentColor}25`}
        >{t}</span>
      ))}
    </div>

    <!-- CTA link -->
    {link && (
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="group/cta inline-flex items-center gap-2 font-bold text-sm transition-colors duration-200"
        style={`color:${accentColor}`}
      >
        {linkText || "Ver projecto"}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200 group-hover/cta:translate-x-0.5 group-hover/cta:-translate-y-0.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    )}

  </div>
</div>

<script>
  // 3D tilt effect — desktop / pointer:fine only
  if (
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
    window.matchMedia('(pointer: fine)').matches
  ) {
    document.querySelectorAll<HTMLElement>('.portfolio-card').forEach((card) => {
      card.addEventListener('mouseenter', () => {
        card.style.transition = 'none';
      });

      card.addEventListener('mousemove', (e: MouseEvent) => {
        const r = card.getBoundingClientRect();
        const x = e.clientX - r.left;
        const y = e.clientY - r.top;
        const rx = ((y - r.height / 2) / (r.height / 2)) * -4;
        const ry = ((x - r.width  / 2) / (r.width  / 2)) *  4;
        card.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-6px) scale(1.01)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transition = 'transform 0.55s cubic-bezier(0.16,1,0.3,1), box-shadow 0.55s ease';
        card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) translateY(0) scale(1)';
        setTimeout(() => { card.style.transition = ''; }, 560);
      });
    });
  }
</script>
