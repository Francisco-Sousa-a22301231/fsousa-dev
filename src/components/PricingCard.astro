---
interface Props {
  title: string;
  description: string;
  price: string;
  priceMax?: string;
  priceNote: string;
  features: string[];
  highlighted?: boolean;
  ctaText: string;
  ctaLink: string;
}

const { title, description, price, priceMax, priceNote, features, highlighted = false, ctaText, ctaLink } = Astro.props;
---

<div class:list={[
  "pricing-card flex flex-col p-8 sm:p-10 bg-[var(--color-bg)]",
  highlighted && "relative"
]}>
  {highlighted && (
    <span class="absolute -top-px left-0 right-0 h-px bg-[var(--color-accent)]"></span>
  )}

  <div class="mb-8">
    {highlighted && (
      <span class="inline-block text-[var(--text-xs)] font-medium uppercase tracking-[0.1em] text-[var(--color-accent)] mb-4">Mais popular</span>
    )}
    <h3 class="text-xl font-light tracking-tight text-[var(--color-text)] mb-2">{title}</h3>
    <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">{description}</p>
  </div>

  <div class="mb-8">
    <div class="flex items-baseline gap-2">
      <span class="text-4xl font-light tracking-tight text-[var(--color-text)]">{price}</span>
      {priceMax && <span class="text-lg font-light text-[var(--color-text-subtle)]">– {priceMax}</span>}
    </div>
    <p class="text-[var(--text-xs)] text-[var(--color-text-subtle)] mt-2">{priceNote}</p>
  </div>

  <ul class="space-y-3 mb-10 flex-1">
    {features.map(feature => (
      <li class="flex items-start gap-3 text-[var(--text-small)] text-[var(--color-text-muted)]">
        <span class="text-[var(--color-text-subtle)] mt-1 flex-shrink-0">—</span>
        {feature}
      </li>
    ))}
  </ul>

  <a
    href={ctaLink}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "link-pill justify-center magnetic-btn text-center",
      highlighted ? "bg-[var(--color-text)] text-[var(--color-bg)] border-[var(--color-text)] hover:bg-[var(--color-accent)] hover:border-[var(--color-accent)]" : ""
    ]}
    data-cursor="expand"
  >
    {ctaText}
  </a>
</div>
