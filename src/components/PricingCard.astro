---
import { t } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  features: string[];
  highlighted?: boolean;
  ctaText: string;
  ctaLink: string;
  locale?: string;
  index?: number;
}

const { title, description, features, highlighted = false, ctaText, ctaLink, locale = 'pt', index = 1 } = Astro.props;
const serviceNumber = String(index).padStart(2, '0');
---

<div class:list={[
  "service-card group relative flex flex-col",
  highlighted && "service-card--highlighted"
]}>
  {/* Top accent line */}
  <div class:list={[
    "h-[2px] w-full rounded-t-2xl",
    highlighted ? "bg-[var(--color-accent)]" : "bg-[var(--color-border)]"
  ]}></div>

  <div class="flex flex-col flex-1 p-8 sm:p-10">
    {/* Number + badge */}
    <div class="flex items-center justify-between mb-8">
      <span class="text-[var(--text-xs)] font-mono text-[var(--color-text-subtle)] tracking-wider">{serviceNumber}</span>
      {highlighted && (
        <span class="inline-flex items-center gap-1.5 text-[10px] font-medium uppercase tracking-[0.12em] text-[var(--color-accent)] px-3 py-1.5 border border-[var(--color-accent)]/20 rounded-full badge-shimmer">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
          {t(locale, 'services.popular')}
        </span>
      )}
    </div>

    {/* Title + description */}
    <div class="mb-8">
      <h3 class="text-2xl font-light tracking-tight text-[var(--color-text)] mb-3 group-hover:text-[var(--color-accent)] transition-colors duration-300">{title}</h3>
      <p class="text-[var(--text-small)] text-[var(--color-text-muted)] leading-relaxed font-light">{description}</p>
    </div>

    {/* Divider */}
    <div class="w-full h-px bg-[var(--color-border)] mb-8"></div>

    {/* Features */}
    <ul class="space-y-4 mb-10 flex-1">
      {features.map((feature) => (
        <li class="flex items-start gap-3 text-[var(--text-small)] text-[var(--color-text-muted)] font-light">
          <span class:list={[
            "mt-1 flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center",
            highlighted
              ? "bg-[var(--color-accent)]/10 text-[var(--color-accent)]"
              : "bg-[var(--color-text)]/5 text-[var(--color-text-subtle)]"
          ]}>
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          {feature}
        </li>
      ))}
    </ul>

    {/* CTA */}
    <a
      href={ctaLink}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "service-card-cta flex items-center justify-center gap-2 py-3.5 px-6 rounded-full text-[var(--text-small)] font-medium transition-all duration-300",
        highlighted
          ? "bg-[var(--color-accent)] text-white hover:shadow-lg hover:shadow-[var(--color-accent)]/20 hover:-translate-y-0.5"
          : "border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-text)] hover:bg-[var(--color-text)] hover:text-[var(--color-bg)]"
      ]}
    >
      {ctaText}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>
  </div>
</div>
