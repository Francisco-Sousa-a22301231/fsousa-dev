---
import { t } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  features: string[];
  highlighted?: boolean;
  ctaText: string;
  ctaLink: string;
  locale?: string;
}

const { title, description, features, highlighted = false, ctaText, ctaLink, locale = 'pt' } = Astro.props;
---

<div class:list={[
  "pricing-card flex flex-col p-8 sm:p-10 relative",
  highlighted ? "pricing-card--highlighted bg-white" : "bg-[var(--color-bg)]"
]}>
  {/* Gradient border glow for highlighted card */}
  {highlighted && (
    <div class="pricing-card-glow" aria-hidden="true"></div>
  )}

  {/* Header */}
  <div class="mb-8">
    {highlighted && (
      <span class="inline-block text-[var(--text-xs)] font-medium uppercase tracking-[0.1em] text-[var(--color-accent)] mb-4 badge-shimmer px-2 py-1 border border-[var(--color-accent)]/20 rounded-full">
        {t(locale, 'services.popular')}
      </span>
    )}
    <h3 class="text-xl font-light tracking-tight text-[var(--color-text)] mb-2">{title}</h3>
    <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">{description}</p>
  </div>

  {/* Features */}
  <ul class="space-y-3 mb-10 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-[var(--text-small)] text-[var(--color-text-muted)]">
        <span class:list={[
          "mt-0.5 flex-shrink-0",
          highlighted ? "text-[var(--color-accent)]" : "text-[var(--color-text-subtle)]"
        ]}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        {feature}
      </li>
    ))}
  </ul>

  {/* CTA */}
  <a
    href={ctaLink}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "link-pill justify-center text-center transition-all duration-300",
      highlighted
        ? "bg-[var(--color-accent)] text-white border-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] hover:border-[var(--color-accent-hover)] hover:shadow-lg hover:shadow-[#FA5D29]/20"
        : "text-[var(--color-text)] border-[var(--color-border)] hover:border-[var(--color-text)] hover:bg-[var(--color-text)] hover:text-[var(--color-bg)]"
    ]}
  >
    {ctaText}
  </a>
</div>
