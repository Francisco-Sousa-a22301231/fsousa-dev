---
import { t } from '../i18n/utils';

interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;
---

<section class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
        <!-- Left column: label + photo -->
        <div class="md:col-span-4">
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-8" data-animate>{t(locale, 'about.label')}</p>

          <!-- Profile photo with creative frame -->
          <div class="about-photo-wrapper relative w-56 h-64 sm:w-64 sm:h-72" data-animate>
            <!-- Accent shape behind photo -->
            <div class="about-accent-shape absolute -inset-3 rounded-[2rem] opacity-20" style="background: linear-gradient(135deg, #FA5D29, #f97316, #fbbf24); filter: blur(20px);"></div>
            <div class="about-accent-border absolute -inset-[2px] rounded-[1.5rem]" style="background: linear-gradient(135deg, #FA5D29, transparent 60%);"></div>

            <!-- Photo container -->
            <div class="relative w-full h-full rounded-[1.5rem] overflow-hidden bg-[var(--color-bg)]" style="padding: 2px;">
              <div class="w-full h-full rounded-[calc(1.5rem-2px)] overflow-hidden">
                <img src="/profile.webp" alt="Francisco Sousa" class="about-photo w-full h-full object-cover object-top" loading="lazy" />
              </div>
            </div>

            <!-- Floating badge: top-right -->
            <div class="about-badge absolute -top-3 -right-3 bg-[var(--color-accent)] text-white text-[var(--text-xs)] font-medium px-3 py-1.5 rounded-full shadow-lg backdrop-blur-sm">
              Full-Stack Dev
            </div>

            <!-- Floating badge: bottom-left -->
            <div class="about-badge about-badge-alt absolute -bottom-3 -left-3 bg-[var(--color-text)] text-[var(--color-bg)] text-[var(--text-xs)] font-medium px-3 py-1.5 rounded-full shadow-lg" style="animation-delay: 1.5s;">
              Flutter &middot; Astro
            </div>

            <!-- Decorative corner dots -->
            <div class="absolute -bottom-6 -right-6 grid grid-cols-3 gap-1.5 opacity-20">
              {Array.from({ length: 9 }).map(() => (
                <div class="w-1 h-1 rounded-full bg-[var(--color-accent)]"></div>
              ))}
            </div>
          </div>

          <!-- Availability -->
          <div class="mt-6 flex items-center gap-2" data-animate>
            <span class="w-2 h-2 bg-[var(--color-whatsapp)] rounded-full"></span>
            <span class="text-[var(--text-xs)] text-[var(--color-text-subtle)]">{t(locale, 'about.available')}</span>
          </div>
        </div>

        <!-- Right column: bio -->
        <div class="md:col-span-8 md:pt-12">
          <h2 class="font-light tracking-tight leading-[0.95] mb-10" style="font-size: var(--text-h1);" data-animate>
            {t(locale, 'about.greeting')}
          </h2>

          <div class="space-y-6 text-[var(--color-text-muted)] text-lg font-light leading-relaxed max-w-2xl">
            <p data-animate>{t(locale, 'about.bio1')}</p>
            <p data-animate>{t(locale, 'about.bio2')}</p>
            <p data-animate>{t(locale, 'about.bio3')}</p>
          </div>

          <!-- Value props — clean, minimal -->
          <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8" data-animate>
            <div>
              <p class="text-[var(--color-text)] font-light text-2xl tracking-tight mb-2">{t(locale, 'about.value_payment_title')}</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">{t(locale, 'about.value_payment_desc')}</p>
            </div>
            <div>
              <p class="text-[var(--color-text)] font-light text-2xl tracking-tight mb-2">{t(locale, 'about.value_whatsapp_title')}</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">{t(locale, 'about.value_whatsapp_desc')}</p>
            </div>
            <div>
              <p class="text-[var(--color-text)] font-light text-2xl tracking-tight mb-2">{t(locale, 'about.value_support_title')}</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">{t(locale, 'about.value_support_desc')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-photo-wrapper:hover .about-photo {
    transform: scale(1.05);
  }

  .about-photo {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-accent-shape {
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.25; transform: scale(1.03); }
  }

  @keyframes float-badge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .about-badge {
    animation: float-badge 3s ease-in-out infinite;
  }

  .about-badge-alt {
    animation: float-badge 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-accent-shape {
      animation: none;
    }
    .about-badge,
    .about-badge-alt {
      animation: none;
    }
    .about-photo {
      transition: none;
    }
  }
</style>
