---
interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<section data-animate class="py-20 sm:py-24 bg-white relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-[#f97316] opacity-[0.03] rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Photo area -->
      <div class="flex justify-center md:justify-start">
        <div class="relative">
          <!-- Main avatar container -->
          <div class="w-64 h-64 sm:w-80 sm:h-80 rounded-2xl bg-gradient-to-br from-[#0f172a] to-[#1e293b] flex items-center justify-center overflow-hidden shadow-xl shadow-[#0f172a]/20">
            <!-- Replace this div with: <img src="/photo.jpg" alt="Francisco Sousa" class="w-full h-full object-cover" /> -->
            <div class="text-center">
              <span class="text-5xl sm:text-7xl font-bold" style="font-family:'Sora',sans-serif; background: linear-gradient(135deg, #f97316, #fb923c, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">FS</span>
              <p class="text-white/40 text-sm mt-2">Foto em breve</p>
            </div>
          </div>
          <!-- Decorative offset border -->
          <div class="absolute -bottom-3 -right-3 w-full h-full rounded-2xl border-2 border-[#f97316]/20 -z-10"></div>
          <!-- Availability badge -->
          <div class="absolute -top-3 -right-3 bg-white border border-slate-200 rounded-xl px-3 py-2 shadow-lg">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 bg-[#25d366] rounded-full animate-pulse"></span>
              <span class="text-xs font-semibold text-[#0f172a]">Disponível</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bio -->
      <div>
        <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Sobre mim</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a] mb-6" style="font-family:'Sora',sans-serif;">
          Olá, sou o Francisco.
        </h2>
        <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
          <p>
            Sou developer full-stack e crio websites e aplicações móveis para negócios que querem <strong class="text-[#0f172a] font-semibold">crescer online</strong>.
          </p>
          <p>
            Trabalho sozinho, sem intermediários — o que significa <strong class="text-[#0f172a] font-semibold">comunicação direta</strong>, decisões rápidas e zero burocracia. Quando fala comigo, fala com quem vai construir o seu projeto do início ao fim.
          </p>
        </div>

        <!-- Value props instead of repeated stats -->
        <div class="mt-8 mb-8 space-y-3">
          <div class="flex items-center gap-3 p-3 bg-[#f8fafc] rounded-xl">
            <div class="w-9 h-9 rounded-lg bg-[#f97316]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#0f172a]">Só paga quando estiver satisfeito</p>
              <p class="text-xs text-slate-400">50% para começar, 50% na entrega final aprovada</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-[#f8fafc] rounded-xl">
            <div class="w-9 h-9 rounded-lg bg-[#25d366]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#0f172a]">Contacto direto por WhatsApp</p>
              <p class="text-xs text-slate-400">Sem formulários, sem esperas — fale diretamente comigo</p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-[#f8fafc] rounded-xl">
            <div class="w-9 h-9 rounded-lg bg-[#3b82f6]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#0f172a]">30 dias de suporte grátis</p>
              <p class="text-xs text-slate-400">Após entrega, continuo disponível sem custo extra</p>
            </div>
          </div>
        </div>

        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white font-bold px-6 py-3.5 rounded-xl transition-all duration-200 shadow-md shadow-[#25d366]/20 active:scale-[0.97] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25d366]/25"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-200 group-hover:scale-110"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar comigo
        </a>
      </div>
    </div>
  </div>
</section>
