---
interface Props {
  question: string;
  answer: string;
  number?: number;
}

const { question, answer, number } = Astro.props;
const displayNumber = number ? String(number).padStart(2, '0') : undefined;
---

<details class="group border-t border-[var(--color-border)]" data-animate>
  <summary class="flex items-center gap-4 py-6 cursor-pointer list-none transition-colors">
    {displayNumber && (
      <span class="text-[var(--text-xs)] text-[var(--color-text-subtle)] font-light tabular-nums flex-shrink-0">{displayNumber}</span>
    )}
    <span class="flex-1 text-lg font-light tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{question}</span>
    <svg class="flex-shrink-0 w-4 h-4 text-[var(--color-text-subtle)] transition-transform duration-300 group-open:rotate-45" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
  </summary>
  <div class="faq-content">
    <div>
      <p class="pb-6 text-[var(--color-text-muted)] font-light leading-relaxed" style:list={[displayNumber && "pl-10"]}>{answer}</p>
    </div>
  </div>
</details>
