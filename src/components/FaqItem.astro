---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
  <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer font-semibold text-[#0f172a] text-lg list-none">
    {question}
    <svg class="flex-shrink-0 w-5 h-5 text-[#f97316] transition-transform group-open:rotate-45" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
  </summary>
  <div class="faq-content">
    <p class="px-6 pb-6 text-slate-500 leading-relaxed">{answer}</p>
  </div>
</details>
