---
const steps = [
  {
    number: "01",
    title: "Descoberta",
    description: "Uma conversa de 15 minutos para perceber o teu negócio, os teus objetivos e o que precisas mesmo.",
    detail: "15 min",
  },
  {
    number: "02",
    title: "Proposta",
    description: "Em 24 horas tens uma proposta clara: o que vamos construir, quanto custa, e quando está pronto.",
    detail: "24 horas",
  },
  {
    number: "03",
    title: "Construção",
    description: "Desenvolvemos o teu projeto com atualizações regulares. Tu vês o progresso, nós fazemos o trabalho.",
    detail: "3–5 dias",
  },
  {
    number: "04",
    title: "Lançamento",
    description: "Entrega, testes, e online. Ficamos disponíveis para suporte após o lançamento.",
    detail: "30 dias suporte",
  },
];
---

<section id="processo" class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <!-- Section header — matches other sections -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
        <div>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Processo</p>
          <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
            Do zero ao online<br/>em 4 passos
          </h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-lg font-light max-w-md" data-animate>
          Sem complicações.
        </p>
      </div>

      <!-- Steps — 4-column grid on desktop, vertical timeline on mobile -->
      <div class="process-grid" id="process-timeline">
        {steps.map((step, i) => (
          <div class="process-step" data-step={i}>
            <!-- Number row with connecting line -->
            <div class="process-step-top">
              <div class="process-step-number">
                <span>{step.number}</span>
              </div>
              {i < steps.length - 1 && <div class="process-step-line" />}
            </div>

            <!-- Content -->
            <div class="process-step-content">
              <div class="process-step-header">
                <h3 class="text-xl sm:text-2xl font-light tracking-tight text-[var(--color-text)]">{step.title}</h3>
                <span class="process-step-detail">{step.detail}</span>
              </div>
              <p class="text-[var(--color-text-muted)] font-light leading-relaxed text-[var(--text-small)] sm:text-base">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== MOBILE: vertical timeline ===== */
  .process-grid {
    display: flex;
    flex-direction: column;
  }

  .process-step {
    display: flex;
    gap: 1.5rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .process-step.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mobile: indicator column with vertical line */
  .process-step-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .process-step-number {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition: border-color 0.5s ease, background-color 0.5s ease;
  }

  .process-step-number span {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-subtle);
    transition: color 0.5s ease;
  }

  .process-step:hover .process-step-number {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
  }

  .process-step:hover .process-step-number span {
    color: white;
  }

  .process-step-line {
    width: 1px;
    flex: 1;
    min-height: 100%;
    background: var(--color-border);
  }

  .process-step-content {
    padding-bottom: 3rem;
    padding-top: 0.75rem;
  }

  .process-step:last-child .process-step-content {
    padding-bottom: 0;
  }

  .process-step-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .process-step-detail {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    white-space: nowrap;
  }

  /* ===== DESKTOP: horizontal 4-column grid ===== */
  @media (min-width: 1024px) {
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }

    .process-step {
      flex-direction: column;
      gap: 0;
    }

    /* Horizontal: number row with connecting line */
    .process-step-top {
      flex-direction: row;
      align-items: center;
      margin-bottom: 2rem;
    }

    .process-step-line {
      width: auto;
      height: 1px;
      min-height: unset;
      flex: 1;
    }

    .process-step-content {
      padding-bottom: 0;
      padding-top: 0;
      padding-right: 2rem;
    }

    .process-step:last-child .process-step-content {
      padding-right: 0;
    }
  }

  @media (min-width: 1024px) {
    .process-step-content {
      padding-right: 3rem;
    }

    .process-step:last-child .process-step-content {
      padding-right: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  const timeline = document.getElementById('process-timeline');
  if (timeline) {
    const steps = timeline.querySelectorAll('.process-step');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      steps.forEach((step) => step.classList.add('is-visible'));
    } else {
      const obs = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          steps.forEach((step, i) => {
            setTimeout(() => step.classList.add('is-visible'), i * 150);
          });
          obs.unobserve(entry.target);
        }
      }, { threshold: 0.1 });
      obs.observe(timeline);
    }
  }
</script>
