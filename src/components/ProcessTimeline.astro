---
---

<section id="processo" data-animate class="py-20 sm:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-bold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">
        Método Rápido
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif;">
        Do zero ao online em 4 passos
      </h2>
      <p class="text-slate-500 text-lg mt-4">Sem complicações. Sem jargão técnico.</p>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden md:block relative">
      <!-- Connecting line (background track) -->
      <div class="absolute top-8 left-[12.5%] right-[12.5%] h-0.5 bg-white/10"></div>
      <!-- Connecting line (animated progress) -->
      <div class="timeline-progress absolute top-8 left-[12.5%] h-0.5 bg-gradient-to-r from-[#f97316] via-[#f97316]/60 to-[#25d366]" style="width: 0%; right: auto; max-width: calc(100% - 25%);"></div>

      <div class="grid grid-cols-4 gap-6 relative">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="1">
          <div class="w-16 h-16 rounded-2xl bg-[#0f172a] flex items-center justify-center mb-5 shadow-lg shadow-[#0f172a]/15 relative z-10">
            <span class="text-[#f97316] font-bold text-xl" style="font-family:'Sora',sans-serif;">1</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Conversa</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Fale comigo no WhatsApp. Percebo o que precisa em <strong class="text-slate-700">15 minutos</strong>.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="2">
          <div class="w-16 h-16 rounded-2xl bg-[#0f172a] flex items-center justify-center mb-5 shadow-lg shadow-[#0f172a]/15 relative z-10">
            <span class="text-[#f97316] font-bold text-xl" style="font-family:'Sora',sans-serif;">2</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Proposta</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Recebe uma proposta clara com <strong class="text-slate-700">preço fixo em 24 horas</strong>.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="3">
          <div class="w-16 h-16 rounded-2xl bg-[#0f172a] flex items-center justify-center mb-5 shadow-lg shadow-[#0f172a]/15 relative z-10">
            <span class="text-[#f97316] font-bold text-xl" style="font-family:'Sora',sans-serif;">3</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Construção</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Construo o seu site. Vê o <strong class="text-slate-700">progresso a cada etapa</strong>.</p>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="4">
          <div class="w-16 h-16 rounded-2xl bg-[#25d366] flex items-center justify-center mb-5 shadow-lg shadow-[#25d366]/20 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Lançamento</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Site online, domínio configurado, <strong class="text-slate-700">Google indexado</strong>.</p>
        </div>
      </div>
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="md:hidden relative pl-14">
      <!-- Vertical line -->
      <div class="absolute left-[18px] top-2 bottom-2 w-px bg-gradient-to-b from-[#f97316]/40 via-[#f97316]/20 to-[#25d366]/40"></div>

      <div class="space-y-8">
        <div class="relative" data-animate>
          <div class="absolute -left-14 top-0 w-9 h-9 rounded-xl bg-[#0f172a] flex items-center justify-center shadow-md z-10">
            <span class="text-[#f97316] font-bold text-sm" style="font-family:'Sora',sans-serif;">1</span>
          </div>
          <div class="bg-[#f8fafc] rounded-xl p-4">
            <h3 class="font-bold text-[#0f172a] text-base mb-1" style="font-family:'Sora',sans-serif;">Conversa</h3>
            <p class="text-slate-500 text-sm">Fale comigo no WhatsApp. Percebo o que precisa em <strong class="text-slate-700">15 minutos</strong>.</p>
          </div>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-14 top-0 w-9 h-9 rounded-xl bg-[#0f172a] flex items-center justify-center shadow-md z-10">
            <span class="text-[#f97316] font-bold text-sm" style="font-family:'Sora',sans-serif;">2</span>
          </div>
          <div class="bg-[#f8fafc] rounded-xl p-4">
            <h3 class="font-bold text-[#0f172a] text-base mb-1" style="font-family:'Sora',sans-serif;">Proposta</h3>
            <p class="text-slate-500 text-sm">Recebe uma proposta clara com <strong class="text-slate-700">preço fixo em 24 horas</strong>.</p>
          </div>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-14 top-0 w-9 h-9 rounded-xl bg-[#0f172a] flex items-center justify-center shadow-md z-10">
            <span class="text-[#f97316] font-bold text-sm" style="font-family:'Sora',sans-serif;">3</span>
          </div>
          <div class="bg-[#f8fafc] rounded-xl p-4">
            <h3 class="font-bold text-[#0f172a] text-base mb-1" style="font-family:'Sora',sans-serif;">Construção</h3>
            <p class="text-slate-500 text-sm">Construo o seu site. Vê o <strong class="text-slate-700">progresso a cada etapa</strong>.</p>
          </div>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-14 top-0 w-9 h-9 rounded-xl bg-[#25d366] flex items-center justify-center shadow-md z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="bg-[#f8fafc] rounded-xl p-4">
            <h3 class="font-bold text-[#0f172a] text-base mb-1" style="font-family:'Sora',sans-serif;">Lançamento</h3>
            <p class="text-slate-500 text-sm">Site online, domínio configurado, <strong class="text-slate-700">Google indexado</strong>.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom time badge + CTA -->
    <div class="flex flex-col items-center mt-10 gap-5">
      <div class="inline-flex items-center gap-2 bg-[#0f172a] text-white text-sm font-semibold px-5 py-2.5 rounded-full shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Tempo total: 3–5 dias úteis
      </div>
      <a
        href="https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20vi%20o%20seu%20site%20e%20estou%20interessado%20num%20or%C3%A7amento%20para%20o%20meu%20neg%C3%B3cio."
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-[0.97] text-white font-bold px-6 py-3 rounded-xl transition-all duration-200 shadow-md shadow-[#25d366]/20 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25d366]/25"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-200 group-hover:scale-110"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Começar agora
      </a>
    </div>
  </div>
</section>
