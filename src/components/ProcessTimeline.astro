---
const steps = [
  { number: "01", title: "Conversa", description: "Fale comigo no WhatsApp. Percebo o que precisa em 15 minutos." },
  { number: "02", title: "Proposta", description: "Recebe uma proposta clara com preço fixo em 24 horas." },
  { number: "03", title: "Construção", description: "Construo o seu site. Vê o progresso a cada etapa." },
  { number: "04", title: "Lançamento", description: "Site online, domínio configurado, Google indexado." },
];
---

<section id="processo" class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
        <div>
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Processo</p>
          <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
            Do zero ao online<br/>em 4 passos
          </h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-lg font-light" data-animate>
          Sem complicações. Sem jargão técnico.
        </p>
      </div>

      <!-- Steps grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-px bg-[var(--color-border)]">
        {steps.map((step, i) => (
          <div class="bg-[var(--color-bg)] p-8 sm:p-10" data-animate data-delay={String(i + 1)}>
            <span class="text-5xl sm:text-6xl font-light tracking-tight text-[var(--color-border)] leading-none mb-6 block" style="color: rgba(0,0,0,0.08);">{step.number}</span>
            <h3 class="text-lg font-light tracking-tight text-[var(--color-text)] mb-3">{step.title}</h3>
            <p class="text-[var(--text-small)] text-[var(--color-text-muted)] font-light leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>

      <!-- Time badge -->
      <div class="mt-12 flex items-center gap-3" data-animate>
        <span class="w-2 h-2 bg-[var(--color-accent)] rounded-full"></span>
        <span class="text-[var(--text-small)] text-[var(--color-text-muted)]">Tempo total: 3–5 dias úteis</span>
      </div>
    </div>
  </div>
</section>
