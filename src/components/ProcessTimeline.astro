---
---

<section id="processo" class="py-20 sm:py-28 bg-[#0f172a] text-white relative overflow-hidden">
  <!-- Background elements -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#f97316] opacity-[0.03] rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-[#3b82f6] opacity-[0.04] rounded-full blur-[100px] translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Como funciona</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold" style="font-family:'Sora',sans-serif;">
        Do zero ao online em 4 passos simples
      </h2>
      <p class="text-white/50 text-lg mt-4 max-w-lg mx-auto">Sem jargão, sem burocracia. Assim é trabalhar comigo.</p>
    </div>

    <!-- Steps grid — desktop -->
    <div class="hidden md:grid grid-cols-4 gap-8 relative">
      <!-- Connecting line track -->
      <div class="absolute top-[52px] left-[12.5%] right-[12.5%] h-px bg-white/10 z-0"></div>
      <!-- Animated progress line -->
      <div class="timeline-progress absolute top-[52px] left-[12.5%] h-px bg-gradient-to-r from-[#f97316] via-[#fb923c] to-[#25d366] z-0" style="width: 0%; max-width: calc(100% - 25%);"></div>

      <!-- Step 1 -->
      <div class="process-step flex flex-col items-center text-center relative z-10" data-animate data-delay="1">
        <div class="process-icon-wrap w-[104px] h-[104px] rounded-2xl bg-white/5 border border-white/10 flex flex-col items-center justify-center mb-6 relative group-hover:border-[#f97316]/40 transition-all duration-300 hover:bg-white/10 hover:border-[#f97316]/30">
          <div class="w-10 h-10 rounded-xl bg-[#f97316]/10 flex items-center justify-center mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <span class="text-[#f97316]/60 text-xs font-bold">01</span>
        </div>
        <h3 class="font-bold text-lg mb-2" style="font-family:'Sora',sans-serif;">Conversa</h3>
        <p class="text-white/50 text-sm leading-relaxed">Fala comigo no WhatsApp. Em 15 minutos percebo exactamente o que precisa.</p>
      </div>

      <!-- Step 2 -->
      <div class="process-step flex flex-col items-center text-center relative z-10" data-animate data-delay="2">
        <div class="process-icon-wrap w-[104px] h-[104px] rounded-2xl bg-white/5 border border-white/10 flex flex-col items-center justify-center mb-6 transition-all duration-300 hover:bg-white/10 hover:border-[#f97316]/30">
          <div class="w-10 h-10 rounded-xl bg-[#f97316]/10 flex items-center justify-center mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <span class="text-[#f97316]/60 text-xs font-bold">02</span>
        </div>
        <h3 class="font-bold text-lg mb-2" style="font-family:'Sora',sans-serif;">Proposta</h3>
        <p class="text-white/50 text-sm leading-relaxed">Recebe uma proposta clara com preço fixo em menos de 24 horas.</p>
      </div>

      <!-- Step 3 -->
      <div class="process-step flex flex-col items-center text-center relative z-10" data-animate data-delay="3">
        <div class="process-icon-wrap w-[104px] h-[104px] rounded-2xl bg-white/5 border border-white/10 flex flex-col items-center justify-center mb-6 transition-all duration-300 hover:bg-white/10 hover:border-[#f97316]/30">
          <div class="w-10 h-10 rounded-xl bg-[#f97316]/10 flex items-center justify-center mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="text-[#f97316]/60 text-xs font-bold">03</span>
        </div>
        <h3 class="font-bold text-lg mb-2" style="font-family:'Sora',sans-serif;">Construção</h3>
        <p class="text-white/50 text-sm leading-relaxed">Construo o seu projeto. Vê o progresso em tempo real, a cada etapa.</p>
      </div>

      <!-- Step 4 -->
      <div class="process-step flex flex-col items-center text-center relative z-10" data-animate data-delay="4">
        <div class="process-icon-wrap w-[104px] h-[104px] rounded-2xl bg-[#25d366]/10 border border-[#25d366]/30 flex flex-col items-center justify-center mb-6 transition-all duration-300 hover:bg-[#25d366]/20">
          <div class="w-10 h-10 rounded-xl bg-[#25d366]/15 flex items-center justify-center mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.8">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <span class="text-[#25d366]/60 text-xs font-bold">04</span>
        </div>
        <h3 class="font-bold text-lg mb-2" style="font-family:'Sora',sans-serif;">Lançamento</h3>
        <p class="text-white/50 text-sm leading-relaxed">Site online, domínio configurado, Google a indexar o seu negócio.</p>
      </div>
    </div>

    <!-- Steps — mobile: vertical stacked cards -->
    <div class="md:hidden space-y-4" data-animate>
      <!-- Step 1 -->
      <div class="flex gap-4 p-4 rounded-2xl bg-white/[0.03] border border-white/10">
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[#f97316] text-xs font-bold">01</span>
            <h3 class="font-bold text-white" style="font-family:'Sora',sans-serif;">Conversa</h3>
          </div>
          <p class="text-white/50 text-sm">Fala comigo no WhatsApp. Em 15 minutos percebo o que precisa.</p>
        </div>
      </div>
      <!-- Step 2 -->
      <div class="flex gap-4 p-4 rounded-2xl bg-white/[0.03] border border-white/10">
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
          </svg>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[#f97316] text-xs font-bold">02</span>
            <h3 class="font-bold text-white" style="font-family:'Sora',sans-serif;">Proposta</h3>
          </div>
          <p class="text-white/50 text-sm">Recebe uma proposta clara com preço fixo em menos de 24 horas.</p>
        </div>
      </div>
      <!-- Step 3 -->
      <div class="flex gap-4 p-4 rounded-2xl bg-white/[0.03] border border-white/10">
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[#f97316] text-xs font-bold">03</span>
            <h3 class="font-bold text-white" style="font-family:'Sora',sans-serif;">Construção</h3>
          </div>
          <p class="text-white/50 text-sm">Construo o seu projeto. Vê o progresso a cada etapa.</p>
        </div>
      </div>
      <!-- Step 4 -->
      <div class="flex gap-4 p-4 rounded-2xl bg-[#25d366]/5 border border-[#25d366]/20">
        <div class="w-12 h-12 rounded-xl bg-[#25d366]/10 border border-[#25d366]/20 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.8">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[#25d366] text-xs font-bold">04</span>
            <h3 class="font-bold text-white" style="font-family:'Sora',sans-serif;">Lançamento</h3>
          </div>
          <p class="text-white/50 text-sm">Site online, domínio configurado, Google a indexar o seu negócio.</p>
        </div>
      </div>
    </div>

    <!-- Bottom stats row -->
    <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto" data-animate>
      <div class="text-center p-4 rounded-xl bg-white/[0.03] border border-white/10">
        <p class="text-2xl font-extrabold text-[#f97316]" style="font-family:'Sora',sans-serif;">15 min</p>
        <p class="text-white/50 text-xs mt-1">para perceber o seu projeto</p>
      </div>
      <div class="text-center p-4 rounded-xl bg-white/[0.03] border border-white/10">
        <p class="text-2xl font-extrabold text-[#f97316]" style="font-family:'Sora',sans-serif;">24 h</p>
        <p class="text-white/50 text-xs mt-1">proposta na sua caixa</p>
      </div>
      <div class="text-center p-4 rounded-xl bg-[#25d366]/5 border border-[#25d366]/20">
        <p class="text-2xl font-extrabold text-[#25d366]" style="font-family:'Sora',sans-serif;">3–5 dias</p>
        <p class="text-white/50 text-xs mt-1">do zero ao online</p>
      </div>
    </div>
  </div>
</section>
