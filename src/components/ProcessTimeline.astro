---
---

<section id="processo" data-animate class="py-20 sm:py-28 bg-[#f8fafc]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-bold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">
        Método Rápido
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif;">
        Do zero ao online em 4 passos
      </h2>
      <p class="text-slate-500 text-lg mt-4">Sem complicações. Sem jargão técnico.</p>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden md:block relative">
      <!-- Connecting line -->
      <div class="absolute top-10 left-[12.5%] right-[12.5%] h-0.5 border-t-2 border-dashed border-[#f97316]/30"></div>

      <div class="grid grid-cols-4 gap-6 relative">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="1">
          <div class="w-20 h-20 rounded-full bg-[#f97316] flex items-center justify-center mb-5 shadow-lg shadow-[#f97316]/20 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <span class="text-[#f97316] font-bold text-sm uppercase tracking-wider mb-2">Passo 1</span>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Conversa</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Fale comigo no WhatsApp. Percebo o que precisa em 15 minutos.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="2">
          <div class="w-20 h-20 rounded-full bg-[#f97316] flex items-center justify-center mb-5 shadow-lg shadow-[#f97316]/20 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <span class="text-[#f97316] font-bold text-sm uppercase tracking-wider mb-2">Passo 2</span>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Proposta</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Recebe uma proposta clara com preço fixo em 24 horas.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="3">
          <div class="w-20 h-20 rounded-full bg-[#f97316] flex items-center justify-center mb-5 shadow-lg shadow-[#f97316]/20 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <span class="text-[#f97316] font-bold text-sm uppercase tracking-wider mb-2">Passo 3</span>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Construção</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Construo o seu site. Vê o progresso a cada etapa.</p>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col items-center text-center" data-animate data-delay="4">
          <div class="w-20 h-20 rounded-full bg-[#f97316] flex items-center justify-center mb-5 shadow-lg shadow-[#f97316]/20 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          </div>
          <span class="text-[#f97316] font-bold text-sm uppercase tracking-wider mb-2">Passo 4</span>
          <h3 class="font-bold text-[#0f172a] text-lg mb-2" style="font-family:'Sora',sans-serif;">Lançamento</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Site online, domínio configurado, Google indexado.</p>
        </div>
      </div>
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="md:hidden relative pl-12">
      <!-- Vertical line -->
      <div class="absolute left-5 top-0 bottom-0 w-0.5 border-l-2 border-dashed border-[#f97316]/30"></div>

      <div class="space-y-10">
        <div class="relative" data-animate>
          <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#f97316] flex items-center justify-center shadow-lg shadow-[#f97316]/20 z-10">
            <span class="text-white font-bold text-sm">1</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-1" style="font-family:'Sora',sans-serif;">Conversa</h3>
          <p class="text-slate-500 text-sm">Fale comigo no WhatsApp. Percebo o que precisa em 15 minutos.</p>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#f97316] flex items-center justify-center shadow-lg shadow-[#f97316]/20 z-10">
            <span class="text-white font-bold text-sm">2</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-1" style="font-family:'Sora',sans-serif;">Proposta</h3>
          <p class="text-slate-500 text-sm">Recebe uma proposta clara com preço fixo em 24 horas.</p>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#f97316] flex items-center justify-center shadow-lg shadow-[#f97316]/20 z-10">
            <span class="text-white font-bold text-sm">3</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-1" style="font-family:'Sora',sans-serif;">Construção</h3>
          <p class="text-slate-500 text-sm">Construo o seu site. Vê o progresso a cada etapa.</p>
        </div>

        <div class="relative" data-animate>
          <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#f97316] flex items-center justify-center shadow-lg shadow-[#f97316]/20 z-10">
            <span class="text-white font-bold text-sm">4</span>
          </div>
          <h3 class="font-bold text-[#0f172a] text-lg mb-1" style="font-family:'Sora',sans-serif;">Lançamento</h3>
          <p class="text-slate-500 text-sm">Site online, domínio configurado, Google indexado.</p>
        </div>
      </div>
    </div>

    <p class="text-center text-slate-400 text-sm mt-10 font-medium">
      <svg class="inline-block mr-1" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Tempo total: 3–5 dias úteis
    </p>
  </div>
</section>
