---
const steps = [
  {
    number: "01",
    emoji: "🎯",
    title: "Descoberta",
    description: "Primeiro, ouvimos. Uma conversa de 15 minutos para perceber o teu negócio, os teus objetivos e o que precisas mesmo.",
  },
  {
    number: "02",
    emoji: "📋",
    title: "Proposta",
    description: "Em 24 horas tens uma proposta clara: o que vamos construir, quanto custa, e quando está pronto.",
  },
  {
    number: "03",
    emoji: "⚡",
    title: "Construção",
    description: "Desenvolvemos o teu projeto com atualizações regulares. Tu vês o progresso, nós fazemos o trabalho.",
  },
  {
    number: "04",
    emoji: "🚀",
    title: "Lançamento",
    description: "Entrega, testes, e online. Ficamos disponíveis para suporte após o lançamento.",
  },
];

const stats = [
  { value: "15 min", label: "Primeira conversa" },
  { value: "24h",    label: "Proposta enviada" },
  { value: "3–5 dias", label: "Primeiros resultados" },
];
---

<section id="processo" class="process-section">
  <div class="process-inner">
    <!-- Header -->
    <div class="process-header">
      <p class="process-label">Processo</p>
      <h2 class="process-title">Do zero ao online<br/>em 4 passos</h2>
      <p class="process-subtitle">Sem complicações. Sem jargão técnico.</p>
    </div>

    <!-- Steps row -->
    <div class="process-steps">
      {steps.map((step, i) => (
        <div class="process-card" data-index={i}>
          <span class="process-step-number">{step.number}</span>
          <span class="process-emoji" aria-hidden="true">{step.emoji}</span>
          <h3 class="process-step-title">{step.title}</h3>
          <p class="process-step-desc">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Stats row -->
    <div class="process-stats">
      {stats.map((stat) => (
        <div class="process-stat">
          <span class="process-stat-value">{stat.value}</span>
          <span class="process-stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    background: #0f0f0f;
    padding: 6rem 1.5rem;
  }

  .process-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .process-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .process-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #f97316;
    margin-bottom: 1rem;
  }

  .process-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .process-subtitle {
    color: #888;
    font-size: 1.125rem;
    font-weight: 300;
  }

  /* Steps */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .process-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }

    /* Connector line */
    .process-steps::before {
      content: '';
      position: absolute;
      top: 2.75rem;
      left: calc(12.5% + 1.5rem);
      right: calc(12.5% + 1.5rem);
      height: 2px;
      background: linear-gradient(90deg, #f97316 0%, #ea580c 100%);
      z-index: 0;
    }
  }

  .process-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    position: relative;
    z-index: 1;

    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  @media (min-width: 768px) {
    .process-card {
      border-radius: 0;
      border-right: none;
      align-items: center;
      text-align: center;
    }

    .process-card:first-child {
      border-radius: 1rem 0 0 1rem;
    }

    .process-card:last-child {
      border-radius: 0 1rem 1rem 0;
      border-right: 1px solid #2a2a2a;
    }
  }

  .process-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .process-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .process-step-number {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #f97316;
  }

  .process-emoji {
    font-size: 2rem;
    line-height: 1;
    display: block;
    position: relative;
    z-index: 1;
  }

  .process-step-title {
    font-size: 1.125rem;
    font-weight: 500;
    color: #ffffff;
    margin: 0;
  }

  .process-step-desc {
    font-size: 0.9rem;
    font-weight: 300;
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  /* Stats */
  .process-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    border-top: 1px solid #2a2a2a;
    padding-top: 3rem;
    align-items: center;
  }

  @media (min-width: 640px) {
    .process-stats {
      flex-direction: row;
      justify-content: center;
      gap: 4rem;
    }
  }

  .process-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }

  .process-stat-value {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 300;
    color: #f97316;
    letter-spacing: -0.02em;
  }

  .process-stat-label {
    font-size: 0.8rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.process-card').forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i * 100}ms`;
    observer.observe(card);
  });
</script>
