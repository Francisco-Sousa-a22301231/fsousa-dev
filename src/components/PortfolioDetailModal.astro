---
import { t } from '../i18n/utils';

interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;
---

<!-- Portfolio Detail Modal (hidden by default, populated via JS) -->
<div id="portfolio-modal" class="portfolio-modal" aria-hidden="true" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="portfolio-modal-backdrop" id="portfolio-modal-backdrop"></div>

  <!-- Modal content -->
  <div class="portfolio-modal-content" id="portfolio-modal-content">
    <!-- Header -->
    <div class="portfolio-modal-header">
      <div>
        <p class="text-[var(--text-xs)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)]" id="modal-tag"></p>
      </div>
      <button id="portfolio-modal-close" class="portfolio-modal-close" aria-label={t(locale, 'portfolio.detail_close')}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Hero -->
    <div class="portfolio-modal-hero">
      <div class="portfolio-modal-placeholder portfolio-modal-placeholder-hero">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
        </svg>
        <span>Hero screenshot</span>
      </div>
      <div class="portfolio-modal-hero-overlay">
        <h2 class="portfolio-modal-title" id="modal-title"></h2>
      </div>
    </div>

    <!-- Gallery -->
    <div class="portfolio-modal-section">
      <p class="portfolio-modal-section-label" id="modal-gallery-label">{t(locale, 'portfolio.detail_gallery')}</p>
      <div class="portfolio-modal-gallery" id="modal-gallery">
        <div class="portfolio-modal-placeholder portfolio-modal-gallery-item">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <span>Screenshot 1</span>
        </div>
        <div class="portfolio-modal-placeholder portfolio-modal-gallery-item">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <span>Screenshot 2</span>
        </div>
        <div class="portfolio-modal-placeholder portfolio-modal-gallery-item">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <span>Screenshot 3</span>
        </div>
        <div class="portfolio-modal-placeholder portfolio-modal-gallery-item">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <span>Screenshot 4</span>
        </div>
        <div class="portfolio-modal-placeholder portfolio-modal-gallery-item">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <span>Screenshot 5</span>
        </div>
      </div>
    </div>

    <!-- Details grid -->
    <div class="portfolio-modal-details">
      <!-- Left column: Challenge + Solution + Description -->
      <div class="portfolio-modal-details-left">
        <div class="portfolio-modal-detail-block">
          <h3 class="portfolio-modal-detail-heading" id="modal-challenge-label">{t(locale, 'portfolio.detail_challenge')}</h3>
          <p class="portfolio-modal-detail-text" id="modal-challenge"></p>
        </div>

        <div class="portfolio-modal-detail-block">
          <h3 class="portfolio-modal-detail-heading" id="modal-solution-label">{t(locale, 'portfolio.detail_solution')}</h3>
          <p class="portfolio-modal-detail-text" id="modal-solution"></p>
        </div>

        <div class="portfolio-modal-detail-block">
          <h3 class="portfolio-modal-detail-heading" id="modal-features-label">{t(locale, 'portfolio.detail_features')}</h3>
          <ul class="portfolio-modal-features" id="modal-features"></ul>
        </div>
      </div>

      <!-- Right column: Metrics + Tech + Result -->
      <div class="portfolio-modal-details-right">
        <!-- Metrics -->
        <div class="portfolio-modal-metrics" id="modal-metrics"></div>

        <!-- Tech stack -->
        <div class="portfolio-modal-tech" id="modal-tech"></div>

        <!-- Result -->
        <div class="portfolio-modal-result-block">
          <p class="portfolio-modal-result" id="modal-result"></p>
        </div>

        <!-- CTA -->
        <div class="portfolio-modal-cta">
          <a id="modal-link" href="#" target="_blank" rel="noopener noreferrer" class="portfolio-modal-visit-btn" style="display:none;">
            <span id="modal-link-text">{t(locale, 'portfolio.detail_visit')}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="portfolio-modal-footer">
      <button id="portfolio-modal-back" class="portfolio-modal-back-btn">
        &larr; {t(locale, 'portfolio.detail_back')}
      </button>
    </div>
  </div>
</div>
