---
interface Props {
  waLink: string;
}
const { waLink } = Astro.props;
---

<section id="contacto-form" class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[1400px] mx-auto">
      <!-- Section header -->
      <div class="mb-16 md:mb-24">
        <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-6" data-animate>Contacto</p>
        <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
          Pronto para ter<br/>mais clientes?
        </h2>
      </div>

      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Left: WhatsApp + trust -->
        <div data-animate>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="link-pill magnetic-btn inline-flex items-center gap-3 text-lg bg-[var(--color-text)] text-[var(--color-bg)] border-[var(--color-text)] hover:bg-[var(--color-whatsapp)] hover:border-[var(--color-whatsapp)] mb-6"
            data-cursor="expand"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Falar no WhatsApp
          </a>

          <p class="text-[var(--text-small)] text-[var(--color-text-subtle)] mb-12">
            Tempo médio de resposta: menos de 1 hora
          </p>

          <!-- Trust signals -->
          <div class="space-y-8">
            <div>
              <p class="text-[var(--color-text)] font-light text-lg mb-1">Sem risco</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">50% só quando estiver satisfeito. Sem contratos longos.</p>
            </div>
            <div>
              <p class="text-[var(--color-text)] font-light text-lg mb-1">Contacto direto</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Fale diretamente comigo, sem intermediários.</p>
            </div>
            <div>
              <p class="text-[var(--color-text)] font-light text-lg mb-1">Entrega rápida</p>
              <p class="text-[var(--text-small)] text-[var(--color-text-subtle)]">Website pronto em 3–5 dias úteis.</p>
            </div>
          </div>

          <!-- Contact info -->
          <div class="mt-12 pt-8 border-t border-[var(--color-border)] space-y-3">
            <a href="tel:+351939021876" class="link-underline text-[var(--text-small)] text-[var(--color-text-muted)] block">939 021 876</a>
            <a href="mailto:franciscobarrososousa@gmail.com" class="link-underline text-[var(--text-small)] text-[var(--color-text-muted)] block">franciscobarrososousa@gmail.com</a>
          </div>
        </div>

        <!-- Right: Contact form -->
        <div data-animate>
          <div id="form-container">
            <h3 class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-10">Envie uma mensagem</h3>
            <form
              id="contact-form"
              action="https://formsubmit.co/franciscobarrososousa@gmail.com"
              method="POST"
              class="space-y-0"
            >
              <input type="hidden" name="_subject" value="Novo contacto — fsousa.dev" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_next" value="https://fsousa-dev.pages.dev/obrigado" />

              <div>
                <label for="nome" class="sr-only">Nome</label>
                <input
                  id="nome"
                  type="text"
                  name="nome"
                  required
                  placeholder="Nome"
                  class="form-input"
                />
              </div>

              <div>
                <label for="telefone" class="sr-only">Telemóvel</label>
                <input
                  id="telefone"
                  type="tel"
                  name="telefone"
                  required
                  placeholder="Telemóvel"
                  class="form-input"
                />
              </div>

              <div>
                <label for="email" class="sr-only">Email</label>
                <input
                  id="email"
                  type="email"
                  name="email"
                  placeholder="Email (opcional)"
                  class="form-input"
                />
              </div>

              <!-- Service selector -->
              <fieldset class="pt-6 pb-6 border-b border-[var(--color-border)]">
                <legend class="text-[var(--text-small)] text-[var(--color-text-subtle)] mb-4">O que procura?</legend>
                <div class="flex flex-wrap gap-2">
                  <label class="flex items-center gap-2 border border-[var(--color-border)] px-4 py-2 rounded-full cursor-pointer hover:border-[var(--color-text)] transition-colors has-[:checked]:border-[var(--color-text)] has-[:checked]:bg-[var(--color-text)] has-[:checked]:text-[var(--color-bg)]">
                    <input type="radio" name="servico" value="Página Web (€300-600)" class="sr-only" />
                    <span class="text-[var(--text-small)]">Página Web</span>
                  </label>
                  <label class="flex items-center gap-2 border border-[var(--color-border)] px-4 py-2 rounded-full cursor-pointer hover:border-[var(--color-text)] transition-colors has-[:checked]:border-[var(--color-text)] has-[:checked]:bg-[var(--color-text)] has-[:checked]:text-[var(--color-bg)]">
                    <input type="radio" name="servico" value="Website Completo (€800-1500)" class="sr-only" />
                    <span class="text-[var(--text-small)]">Website Completo</span>
                  </label>
                  <label class="flex items-center gap-2 border border-[var(--color-border)] px-4 py-2 rounded-full cursor-pointer hover:border-[var(--color-text)] transition-colors has-[:checked]:border-[var(--color-text)] has-[:checked]:bg-[var(--color-text)] has-[:checked]:text-[var(--color-bg)]">
                    <input type="radio" name="servico" value="App Móvel (a partir de €2000)" class="sr-only" />
                    <span class="text-[var(--text-small)]">App Móvel</span>
                  </label>
                  <label class="flex items-center gap-2 border border-[var(--color-border)] px-4 py-2 rounded-full cursor-pointer hover:border-[var(--color-text)] transition-colors has-[:checked]:border-[var(--color-text)] has-[:checked]:bg-[var(--color-text)] has-[:checked]:text-[var(--color-bg)]">
                    <input type="radio" name="servico" value="Ainda não sei" class="sr-only" checked />
                    <span class="text-[var(--text-small)]">Ainda não sei</span>
                  </label>
                </div>
              </fieldset>

              <div>
                <label for="mensagem" class="sr-only">Mensagem</label>
                <textarea
                  id="mensagem"
                  name="mensagem"
                  rows="3"
                  placeholder="Conte-me sobre o seu projeto..."
                  class="form-input resize-none"
                ></textarea>
              </div>

              <div class="pt-8">
                <button
                  id="submit-btn"
                  type="submit"
                  class="link-pill magnetic-btn bg-[var(--color-text)] text-[var(--color-bg)] border-[var(--color-text)] hover:bg-[var(--color-accent)] hover:border-[var(--color-accent)]"
                  data-cursor="expand"
                >
                  Enviar mensagem
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </div>
            </form>
          </div>

          <!-- Success state -->
          <div id="form-success" class="hidden py-16">
            <h3 class="text-2xl font-light tracking-tight text-[var(--color-text)] mb-4">Obrigado!</h3>
            <p class="text-[var(--color-text-muted)] font-light mb-8">Respondo em menos de 2 horas.</p>
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="link-pill inline-flex items-center gap-2"
              data-cursor="expand"
            >
              Resposta mais rápida no WhatsApp
            </a>
          </div>

          <!-- Error state -->
          <div id="form-error" class="hidden py-16">
            <h3 class="text-2xl font-light tracking-tight text-[var(--color-text)] mb-4">Algo correu mal</h3>
            <p class="text-[var(--color-text-muted)] font-light mb-8">Tente por WhatsApp — respondo em minutos.</p>
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="link-pill inline-flex items-center gap-2"
              data-cursor="expand"
            >
              Falar no WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container')!;
  const formSuccess = document.getElementById('form-success')!;
  const formError = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('submit-btn')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'A enviar…';
    submitBtn.setAttribute('disabled', 'true');

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' },
      });

      if (res.ok) {
        formContainer.classList.add('hidden');
        formSuccess.classList.remove('hidden');
        formSuccess.classList.add('form-success-reveal');
      } else {
        formContainer.classList.add('hidden');
        formError.classList.remove('hidden');
        formError.classList.add('form-success-reveal');
      }
    } catch {
      formContainer.classList.add('hidden');
      formError.classList.remove('hidden');
      formError.classList.add('form-success-reveal');
    }
  });
</script>
