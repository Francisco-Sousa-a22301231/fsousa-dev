---
import { t, getLocalizedPath } from '../i18n/utils';

interface Props {
  waLink: string;
  locale?: string;
}

const { waLink, locale = 'pt' } = Astro.props;
const redirectUrl = `https://fsousa-dev.pages.dev${getLocalizedPath('/obrigado', locale)}`;
---

<section id="contacto-form" class="relative">
  <div class="section-divider"></div>
  <div class="py-[var(--section-py)] px-6 sm:px-8">
    <div class="max-w-[700px] mx-auto">
      <!-- Section header -->
      <div class="mb-12" data-animate>
        <h2 class="font-light tracking-tight leading-[0.95] mb-4" style="font-size: var(--text-h1);">
          {t(locale, 'contact.title')}
        </h2>
        <p class="text-lg text-[var(--color-text-muted)] font-light">
          {t(locale, 'contact.subtitle')}
        </p>
      </div>

      <!-- Contact form -->
      <div data-animate>
        <div id="form-container">
          <form
            id="contact-form"
            action="https://formsubmit.co/franciscobarrososousa@gmail.com"
            method="POST"
            class="space-y-0"
          >
            <input type="hidden" name="_subject" value="Novo contacto — fsousa.dev" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value={redirectUrl} />

            <div>
              <label for="nome" class="sr-only">{t(locale, 'contact.name_placeholder')}</label>
              <input
                id="nome"
                type="text"
                name="nome"
                required
                placeholder={t(locale, 'contact.name_placeholder')}
                class="form-input"
              />
            </div>

            <div>
              <label for="email" class="sr-only">{t(locale, 'contact.email_placeholder')}</label>
              <input
                id="email"
                type="email"
                name="email"
                required
                placeholder={t(locale, 'contact.email_placeholder')}
                class="form-input"
              />
            </div>

            <div>
              <label for="mensagem" class="sr-only">{t(locale, 'contact.message_placeholder')}</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="4"
                placeholder={t(locale, 'contact.message_placeholder')}
                class="form-input resize-none"
              ></textarea>
            </div>

            <div class="pt-8">
              <button
                id="submit-btn"
                type="submit"
                class="link-pill magnetic-btn w-full justify-center bg-[var(--color-accent)] text-white border-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] hover:border-[var(--color-accent-hover)]"
                data-cursor="expand"
                data-submitting-text={t(locale, 'contact.submitting')}
              >
                {t(locale, 'contact.submit')}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </div>
          </form>

          <!-- WhatsApp link below submit -->
          <div class="mt-6 text-center">
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-[var(--text-small)] text-[var(--color-text-muted)] hover:text-[var(--color-whatsapp)] transition-colors"
              data-cursor="expand"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t(locale, 'contact.whatsapp_alt')}
            </a>
          </div>
        </div>

        <!-- Success state -->
        <div id="form-success" class="hidden py-16 text-center">
          <h3 class="text-2xl font-light tracking-tight text-[var(--color-text)] mb-4">{t(locale, 'contact.success_title')}</h3>
          <p class="text-[var(--color-text-muted)] font-light mb-8">{t(locale, 'contact.success_subtitle')}</p>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="link-pill inline-flex items-center gap-2 text-[var(--color-text)]"
            data-cursor="expand"
          >
            {t(locale, 'contact.success_wa')}
          </a>
        </div>

        <!-- Error state -->
        <div id="form-error" class="hidden py-16 text-center">
          <h3 class="text-2xl font-light tracking-tight text-[var(--color-text)] mb-4">{t(locale, 'contact.error_title')}</h3>
          <p class="text-[var(--color-text-muted)] font-light mb-8">{t(locale, 'contact.error_subtitle')}</p>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="link-pill inline-flex items-center gap-2 text-[var(--color-text)]"
            data-cursor="expand"
          >
            {t(locale, 'contact.error_wa')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container')!;
  const formSuccess = document.getElementById('form-success')!;
  const formError = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('submit-btn')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submittingText = submitBtn.getAttribute('data-submitting-text') || 'Sending…';
    submitBtn.textContent = submittingText;
    submitBtn.setAttribute('disabled', 'true');

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' },
      });

      if (res.ok) {
        formContainer.classList.add('hidden');
        formSuccess.classList.remove('hidden');
        formSuccess.classList.add('form-success-reveal');
      } else {
        formContainer.classList.add('hidden');
        formError.classList.remove('hidden');
        formError.classList.add('form-success-reveal');
      }
    } catch {
      formContainer.classList.add('hidden');
      formError.classList.remove('hidden');
      formError.classList.add('form-success-reveal');
    }
  });
</script>
