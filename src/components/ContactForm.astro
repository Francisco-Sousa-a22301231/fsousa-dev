---
interface Props {
  waLink: string;
}
const { waLink } = Astro.props;
---

<section id="contacto-form" data-animate class="py-20 sm:py-28 bg-[#0f172a] text-white relative overflow-hidden">
  <!-- Background accents -->
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#25d366] opacity-[0.03] rounded-full blur-[100px] -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#f97316] opacity-[0.04] rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-wider">
        <span class="w-2 h-2 bg-[#f97316] rounded-full animate-pulse"></span>
        Disponível agora
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-5 leading-tight" style="font-family:'Sora',sans-serif;">
        Pronto para ter <span class="hero-gradient-text">mais clientes?</span>
      </h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Peça um orçamento gratuito. Sem compromisso. Resposta em menos de 2 horas.
      </p>
    </div>

    <!-- Two-column layout: WhatsApp + Form -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto items-start">

      <!-- Left: WhatsApp CTA + trust signals -->
      <div class="flex flex-col items-center lg:items-start text-center lg:text-left lg:sticky lg:top-28">
        <!-- WhatsApp CTA -->
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-wa-cta group relative inline-flex items-center justify-center gap-4 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-[0.97] text-white font-bold text-xl px-10 py-5 rounded-2xl transition-all duration-200 shadow-xl shadow-[#25d366]/30 hover:shadow-2xl hover:shadow-[#25d366]/35 hover:-translate-y-0.5 w-full sm:w-auto"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar no WhatsApp agora
        </a>

        <p class="text-white/40 text-sm mt-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Tempo médio de resposta: menos de 1 hora
        </p>

        <!-- Trust signals -->
        <div class="mt-10 space-y-5 w-full max-w-sm">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#f97316]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Sem risco</p>
              <p class="text-white/40 text-sm">50% só quando estiver satisfeito. Sem contratos longos.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#25d366]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 11.9 19.79 19.79 0 0 1 1.27 3.3 2 2 0 0 1 3.24 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.1a16 16 0 0 0 6 6l.62-.58a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 16h.72z"/></svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Contacto direto</p>
              <p class="text-white/40 text-sm">Fale diretamente comigo, sem intermediários.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Entrega rápida</p>
              <p class="text-white/40 text-sm">Website pronto em 3–5 dias úteis.</p>
            </div>
          </div>
        </div>

        <!-- Contact info -->
        <div class="mt-10 pt-8 border-t border-white/[0.06] w-full max-w-sm space-y-3">
          <a href="tel:+351939021876" class="flex items-center gap-3 text-white/50 hover:text-white text-sm transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 11.9 19.79 19.79 0 0 1 1.27 3.3 2 2 0 0 1 3.24 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.1a16 16 0 0 0 6 6l.62-.58a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 16h.72z"/></svg>
            939 021 876
          </a>
          <a href="mailto:franciscobarrososousa@gmail.com" class="flex items-center gap-3 text-white/50 hover:text-white text-sm transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            franciscobarrososousa@gmail.com
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div id="form-wrapper" class="bg-white rounded-2xl p-6 sm:p-8">
        <div id="form-container">
          <h3 class="text-[#0f172a] text-xl font-bold mb-6">Envie uma mensagem</h3>
          <form
            id="contact-form"
            action="https://formsubmit.co/franciscobarrososousa@gmail.com"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="_subject" value="Novo contacto — fsousa.dev" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://fsousa-dev.pages.dev/obrigado" />

            <div>
              <label for="nome" class="block text-sm font-semibold text-slate-700 mb-1.5">Nome</label>
              <input
                id="nome"
                type="text"
                name="nome"
                required
                placeholder="O seu nome"
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-[#0f172a] text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#f97316] focus:border-transparent transition"
              />
            </div>

            <div>
              <label for="telefone" class="block text-sm font-semibold text-slate-700 mb-1.5">Telemóvel</label>
              <input
                id="telefone"
                type="tel"
                name="telefone"
                required
                placeholder="+351 9XX XXX XXX"
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-[#0f172a] text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#f97316] focus:border-transparent transition"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email <span class="text-slate-400 font-normal">(opcional)</span></label>
              <input
                id="email"
                type="email"
                name="email"
                placeholder="o-seu@email.com"
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-[#0f172a] text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#f97316] focus:border-transparent transition"
              />
            </div>

            <!-- Pre-qualifier -->
            <fieldset>
              <legend class="block text-sm font-semibold text-slate-700 mb-2">O que procura?</legend>
              <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-[#f97316]/50 transition has-[:checked]:border-[#f97316] has-[:checked]:bg-[#f97316]/5">
                  <input type="radio" name="servico" value="Página Web (€300-600)" class="accent-[#f97316]" />
                  <span class="text-sm text-slate-600">Página Web</span>
                </label>
                <label class="flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-[#f97316]/50 transition has-[:checked]:border-[#f97316] has-[:checked]:bg-[#f97316]/5">
                  <input type="radio" name="servico" value="Website Completo (€800-1500)" class="accent-[#f97316]" />
                  <span class="text-sm text-slate-600">Website Completo</span>
                </label>
                <label class="flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-[#f97316]/50 transition has-[:checked]:border-[#f97316] has-[:checked]:bg-[#f97316]/5">
                  <input type="radio" name="servico" value="App Móvel (a partir de €2000)" class="accent-[#f97316]" />
                  <span class="text-sm text-slate-600">App Móvel</span>
                </label>
                <label class="flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-[#f97316]/50 transition has-[:checked]:border-[#f97316] has-[:checked]:bg-[#f97316]/5">
                  <input type="radio" name="servico" value="Ainda não sei" class="accent-[#f97316]" checked />
                  <span class="text-sm text-slate-600">Ainda não sei</span>
                </label>
              </div>
            </fieldset>

            <div>
              <label for="mensagem" class="block text-sm font-semibold text-slate-700 mb-1.5">Mensagem</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="3"
                placeholder="Olá Francisco, gostava de saber mais sobre..."
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-[#0f172a] text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#f97316] focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <button
              id="submit-btn"
              type="submit"
              class="w-full bg-[#f97316] hover:bg-[#ea6c0a] active:scale-95 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-[#f97316]/20 hover:-translate-y-0.5"
            >
              Enviar Mensagem
            </button>
          </form>
        </div>

        <!-- Success state -->
        <div id="form-success" class="hidden text-center py-8">
          <div class="w-16 h-16 bg-[#25d366]/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="text-[#0f172a] text-2xl font-bold mb-2">Obrigado!</h3>
          <p class="text-slate-500 mb-6">Respondo em menos de 2 horas.</p>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white font-bold px-6 py-3 rounded-xl transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Resposta mais rápida no WhatsApp
          </a>
        </div>

        <!-- Error state -->
        <div id="form-error" class="hidden text-center py-8">
          <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
          </div>
          <h3 class="text-[#0f172a] text-2xl font-bold mb-2">Algo correu mal</h3>
          <p class="text-slate-500 mb-6">Tente por WhatsApp — respondo em minutos.</p>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white font-bold px-6 py-3 rounded-xl transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Falar no WhatsApp
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container')!;
  const formSuccess = document.getElementById('form-success')!;
  const formError = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('submit-btn')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'A enviar\u2026';
    submitBtn.setAttribute('disabled', 'true');

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' },
      });

      if (res.ok) {
        formContainer.classList.add('hidden');
        formSuccess.classList.remove('hidden');
      } else {
        formContainer.classList.add('hidden');
        formError.classList.remove('hidden');
      }
    } catch {
      formContainer.classList.add('hidden');
      formError.classList.remove('hidden');
    }
  });
</script>

<style>
  /* WhatsApp CTA glow ring */
  .contact-wa-cta::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 1.1rem;
    background: rgba(37, 211, 102, 0.4);
    animation: wa-glow-ring 2.5s ease-out infinite;
    z-index: -1;
  }

  @keyframes wa-glow-ring {
    0% { opacity: 0.6; transform: scale(1); }
    70% { opacity: 0; transform: scale(1.08); }
    100% { opacity: 0; transform: scale(1.08); }
  }

  /* Form field focus enhancement */
  #contact-form input:focus,
  #contact-form textarea:focus {
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
  }

  /* Submit button states */
  #submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none !important;
  }

  /* Success animation */
  #form-success:not(.hidden) {
    animation: success-reveal 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes success-reveal {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Error animation */
  #form-error:not(.hidden) {
    animation: success-reveal 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-wa-cta::before { animation: none !important; }
    #form-success:not(.hidden),
    #form-error:not(.hidden) { animation: none !important; }
  }
</style>
