---
interface Props {
  quote: string;
  name: string;
  business: string;
  initial: string;
}

const { quote, name, business, initial } = Astro.props;
---

<div class="testimonial-card flex flex-col bg-white/[0.04] backdrop-blur-sm rounded-2xl p-7 border border-white/10 relative overflow-hidden hover:border-white/20 hover:bg-white/[0.06] transition-all duration-300">
  <!-- Decorative quote mark -->
  <div class="absolute -top-2 -left-1 text-[#f97316]/10 text-8xl font-serif leading-none select-none pointer-events-none" aria-hidden="true">"</div>

  <!-- Stars -->
  <div class="flex gap-0.5 mb-4 relative z-10">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
  </div>

  <p class="text-white/80 leading-relaxed mb-6 flex-1 text-base relative z-10">"{quote}"</p>
  <div class="flex items-center gap-3 pt-4 border-t border-white/10 relative z-10">
    <div class="w-10 h-10 bg-gradient-to-br from-[#f97316] to-[#f59e0b] rounded-full flex items-center justify-center text-white font-bold text-sm" style="font-family:'Sora',sans-serif;">{initial}</div>
    <div>
      <p class="font-semibold text-white text-sm">{name}</p>
      <p class="text-white/40 text-xs">{business}</p>
    </div>
  </div>
</div>
