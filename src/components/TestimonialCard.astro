---
interface Props {
  quote: string;
  name: string;
  business: string;
  initial: string;
}

const { quote, name, business, initial } = Astro.props;
---

<div class="flex flex-col bg-white border-l-4 border-[#f97316] rounded-r-2xl p-7 shadow-sm hover:shadow-md transition-shadow relative">
  <!-- Decorative quote mark -->
  <svg class="absolute top-4 right-4 opacity-10" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="#f97316"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>

  <p class="text-slate-600 leading-relaxed mb-6 flex-1 italic text-lg">"{quote}"</p>
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-[#f97316]/10 rounded-full flex items-center justify-center text-[#f97316] font-bold text-sm">{initial}</div>
    <div>
      <p class="font-semibold text-[#0f172a] text-sm">{name}</p>
      <p class="text-slate-400 text-xs">{business}</p>
    </div>
  </div>
</div>
