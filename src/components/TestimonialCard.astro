---
interface Props {
  quote: string;
  name: string;
  business: string;
}

const { quote, name, business } = Astro.props;
---

<div class="testimonial-card" data-animate>
  <!-- Large quote mark -->
  <span class="block text-6xl font-light leading-none text-[var(--color-border)] select-none mb-6" aria-hidden="true">"</span>

  <p class="text-xl sm:text-2xl font-light leading-relaxed text-[var(--color-text)] mb-8 tracking-tight">
    {quote}
  </p>

  <div class="pt-6 border-t border-[var(--color-border)]">
    <p class="text-[var(--text-small)] font-medium text-[var(--color-text)]">{name}</p>
    <p class="text-[var(--text-xs)] text-[var(--color-text-subtle)]">{business}</p>
  </div>
</div>
