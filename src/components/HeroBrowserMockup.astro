---
---

<div class="hidden lg:flex items-center justify-center relative">
  <!-- Browser window mockup -->
  <div class="relative w-[380px] bg-[#1e293b] rounded-xl border border-white/10 shadow-2xl overflow-hidden">
    <!-- Browser chrome -->
    <div class="flex items-center gap-2 px-4 py-3 bg-[#0f172a] border-b border-white/10">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
      </div>
      <div class="flex-1 bg-white/5 rounded-md px-3 py-1 text-white/40 text-xs font-mono ml-2">
        <span class="typing-url">o-seu-negocio.pt</span>
      </div>
    </div>
    <!-- Browser content -->
    <div class="p-5 space-y-4">
      <!-- Nav bar -->
      <div class="flex items-center justify-between">
        <div class="h-3 bg-white/20 rounded w-20"></div>
        <div class="flex gap-3">
          <div class="h-2 bg-white/10 rounded w-10"></div>
          <div class="h-2 bg-white/10 rounded w-10"></div>
          <div class="h-2 bg-white/10 rounded w-10"></div>
        </div>
      </div>
      <!-- Hero area -->
      <div class="bg-gradient-to-br from-[#f97316]/20 to-[#f97316]/5 rounded-lg p-5 space-y-3">
        <div class="h-4 bg-white/25 rounded w-3/4"></div>
        <div class="h-3 bg-white/15 rounded w-full"></div>
        <div class="h-3 bg-white/15 rounded w-2/3"></div>
        <div class="flex gap-2 mt-3">
          <div class="h-8 bg-[#f97316]/60 rounded-md w-24"></div>
          <div class="h-8 bg-white/10 rounded-md w-20 border border-white/20"></div>
        </div>
      </div>
      <!-- Content blocks -->
      <div class="grid grid-cols-3 gap-2">
        <div class="bg-white/5 rounded-md p-3 space-y-2">
          <div class="w-6 h-6 bg-[#f97316]/20 rounded-md mx-auto"></div>
          <div class="h-2 bg-white/10 rounded w-full"></div>
          <div class="h-2 bg-white/10 rounded w-3/4 mx-auto"></div>
        </div>
        <div class="bg-white/5 rounded-md p-3 space-y-2">
          <div class="w-6 h-6 bg-[#25d366]/20 rounded-md mx-auto"></div>
          <div class="h-2 bg-white/10 rounded w-full"></div>
          <div class="h-2 bg-white/10 rounded w-3/4 mx-auto"></div>
        </div>
        <div class="bg-white/5 rounded-md p-3 space-y-2">
          <div class="w-6 h-6 bg-blue-500/20 rounded-md mx-auto"></div>
          <div class="h-2 bg-white/10 rounded w-full"></div>
          <div class="h-2 bg-white/10 rounded w-3/4 mx-auto"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Phone mockup overlapping bottom-right -->
  <div class="absolute -bottom-6 -right-2 w-[140px] bg-[#1e293b] rounded-[24px] border-2 border-white/15 shadow-2xl overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-4 bg-[#1e293b] rounded-b-xl z-10"></div>
    <div class="p-3 pt-5 space-y-2">
      <div class="h-2.5 bg-white/20 rounded w-3/4"></div>
      <div class="h-2 bg-white/10 rounded w-full"></div>
      <div class="h-2 bg-white/10 rounded w-2/3"></div>
      <div class="bg-[#f97316]/20 rounded-md p-2 mt-2 space-y-1.5">
        <div class="h-2 bg-white/20 rounded w-full"></div>
        <div class="h-2 bg-white/15 rounded w-4/5"></div>
      </div>
      <div class="flex gap-1 mt-2">
        <div class="h-5 bg-[#25d366]/40 rounded w-1/2"></div>
        <div class="h-5 bg-white/10 rounded w-1/2 border border-white/15"></div>
      </div>
      <div class="space-y-1.5 mt-2">
        <div class="h-1.5 bg-white/8 rounded w-full"></div>
        <div class="h-1.5 bg-white/8 rounded w-5/6"></div>
        <div class="h-1.5 bg-white/8 rounded w-full"></div>
      </div>
    </div>
  </div>

  <!-- Performance badge floating top-right -->
  <div class="absolute -top-4 right-4 bg-[#0f172a] border border-[#25d366]/40 rounded-xl px-4 py-3 shadow-lg">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full border-2 border-[#25d366] flex items-center justify-center">
        <span class="text-[#25d366] font-bold text-sm" style="font-family:'Sora',sans-serif;">100</span>
      </div>
      <div>
        <p class="text-white text-xs font-semibold">Performance</p>
        <p class="text-[#25d366] text-[10px]">Google PageSpeed</p>
      </div>
    </div>
  </div>

  <!-- Google stars badge floating top-left -->
  <div class="absolute -top-4 -left-8 bg-[#0f172a] border border-[#f97316]/40 rounded-xl px-4 py-3 shadow-lg">
    <div class="flex items-center gap-2">
      <div class="flex gap-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <p class="text-white text-[10px] font-semibold">5 estrelas</p>
    </div>
  </div>
</div>

<style>
  .typing-url {
    border-right: 2px solid #f97316;
    animation: blink-cursor 1s step-end infinite;
  }
  @keyframes blink-cursor {
    50% { border-color: transparent; }
  }
</style>
