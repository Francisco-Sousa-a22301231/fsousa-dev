<section class="bg-[#0f172a] border-y border-white/10 py-10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-[#f97316] mb-1" style="font-family:'Sora',sans-serif;" data-count="6" data-suffix="+">0</p>
        <p class="text-white/50 text-sm font-medium">Projetos entregues</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-[#f97316] mb-1" style="font-family:'Sora',sans-serif;" data-count="100" data-suffix="/100">0</p>
        <p class="text-white/50 text-sm font-medium">PageSpeed Score</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-[#f97316] mb-1" style="font-family:'Sora',sans-serif;" data-count="2" data-prefix="<" data-suffix="h">0</p>
        <p class="text-white/50 text-sm font-medium">Tempo de resposta</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-[#f97316] mb-1" style="font-family:'Sora',sans-serif;" data-count="0" data-suffix="€">0</p>
        <p class="text-white/50 text-sm font-medium">Mensalidades</p>
      </div>
    </div>
  </div>
</section>
