---
---

<section id="processo" class="py-20 sm:py-28 bg-[#080d18] text-white relative overflow-hidden">
  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-[#f97316] opacity-[0.04] rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#6366f1] opacity-[0.04] rounded-full blur-[120px] translate-x-1/2 translate-y-1/3 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Como funciona</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold" style="font-family:'Sora',sans-serif;">
        Do zero ao online em 4 passos simples
      </h2>
      <p class="text-white/50 text-lg mt-4 max-w-lg mx-auto">Sem jargão, sem burocracia. Assim é trabalhar comigo.</p>
    </div>

    <!-- Step cards — desktop: 4 cols, mobile: 1 col -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

      <!-- Step 1: Descoberta -->
      <div class="process-card relative flex flex-col p-6 rounded-2xl bg-white/[0.04] border border-white/10 hover:bg-white/[0.07] hover:border-[#f97316]/30 transition-colors duration-300">
        <span class="absolute top-4 right-4 text-6xl font-extrabold text-white/[0.05] leading-none select-none" style="font-family:'Sora',sans-serif;" aria-hidden="true">01</span>
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center mb-5 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <span class="text-[#f97316] text-xs font-bold uppercase tracking-widest mb-2">Passo 01</span>
        <h3 class="font-bold text-lg mb-3" style="font-family:'Sora',sans-serif;">Descoberta</h3>
        <p class="text-white/50 text-sm leading-relaxed">Primeiro, ouvimos. Uma conversa de 15 minutos para perceber o teu negócio, objetivos e o que precisas mesmo.</p>
      </div>

      <!-- Step 2: Proposta -->
      <div class="process-card relative flex flex-col p-6 rounded-2xl bg-white/[0.04] border border-white/10 hover:bg-white/[0.07] hover:border-[#f97316]/30 transition-colors duration-300">
        <span class="absolute top-4 right-4 text-6xl font-extrabold text-white/[0.05] leading-none select-none" style="font-family:'Sora',sans-serif;" aria-hidden="true">02</span>
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center mb-5 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <span class="text-[#f97316] text-xs font-bold uppercase tracking-widest mb-2">Passo 02</span>
        <h3 class="font-bold text-lg mb-3" style="font-family:'Sora',sans-serif;">Proposta</h3>
        <p class="text-white/50 text-sm leading-relaxed">Em 24 horas tens uma proposta clara: o que vamos construir, quanto custa, e quando está pronto.</p>
      </div>

      <!-- Step 3: Construção -->
      <div class="process-card relative flex flex-col p-6 rounded-2xl bg-white/[0.04] border border-white/10 hover:bg-white/[0.07] hover:border-[#f97316]/30 transition-colors duration-300">
        <span class="absolute top-4 right-4 text-6xl font-extrabold text-white/[0.05] leading-none select-none" style="font-family:'Sora',sans-serif;" aria-hidden="true">03</span>
        <div class="w-12 h-12 rounded-xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center mb-5 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
        <span class="text-[#f97316] text-xs font-bold uppercase tracking-widest mb-2">Passo 03</span>
        <h3 class="font-bold text-lg mb-3" style="font-family:'Sora',sans-serif;">Construção</h3>
        <p class="text-white/50 text-sm leading-relaxed">Desenvolvemos o teu projeto com atualizações regulares. Tu vês o progresso, nós fazemos o trabalho.</p>
      </div>

      <!-- Step 4: Lançamento -->
      <div class="process-card relative flex flex-col p-6 rounded-2xl bg-[#25d366]/[0.06] border border-[#25d366]/25 hover:bg-[#25d366]/[0.1] hover:border-[#25d366]/40 transition-colors duration-300">
        <span class="absolute top-4 right-4 text-6xl font-extrabold text-[#25d366]/[0.08] leading-none select-none" style="font-family:'Sora',sans-serif;" aria-hidden="true">04</span>
        <div class="w-12 h-12 rounded-xl bg-[#25d366]/10 border border-[#25d366]/25 flex items-center justify-center mb-5 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
          </svg>
        </div>
        <span class="text-[#25d366] text-xs font-bold uppercase tracking-widest mb-2">Passo 04</span>
        <h3 class="font-bold text-lg mb-3" style="font-family:'Sora',sans-serif;">Lançamento</h3>
        <p class="text-white/50 text-sm leading-relaxed">Entrega, testes, e online. Ficamos disponíveis para suporte pós-lançamento.</p>
      </div>

    </div>

    <!-- Stats row -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
      <div class="process-card text-center p-5 rounded-xl bg-white/[0.03] border border-white/10">
        <p class="text-2xl font-extrabold text-[#f97316]" style="font-family:'Sora',sans-serif;">15 min</p>
        <p class="text-white/50 text-xs mt-1">Primeira conversa</p>
      </div>
      <div class="process-card text-center p-5 rounded-xl bg-white/[0.03] border border-white/10">
        <p class="text-2xl font-extrabold text-[#f97316]" style="font-family:'Sora',sans-serif;">24h</p>
        <p class="text-white/50 text-xs mt-1">Proposta enviada</p>
      </div>
      <div class="process-card text-center p-5 rounded-xl bg-[#25d366]/[0.05] border border-[#25d366]/20">
        <p class="text-2xl font-extrabold text-[#25d366]" style="font-family:'Sora',sans-serif;">3–5 dias</p>
        <p class="text-white/50 text-xs mt-1">Primeiros resultados</p>
      </div>
    </div>

  </div>
</section>

<style>
  .process-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .process-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .process-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.process-card').forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i * 100}ms`;
    observer.observe(card);
  });
</script>
