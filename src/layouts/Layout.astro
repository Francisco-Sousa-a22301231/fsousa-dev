---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Criação de Websites em Cascais | Francisco Sousa',
  description = 'Websites rápidos e modernos para negócios em Cascais. Páginas web a partir de €300. Entrega em 5 dias. Peça orçamento grátis.',
} = Astro.props;

const canonicalUrl = 'https://fsousa-dev.pages.dev';
const ogImage = `${canonicalUrl}/og-image.png`;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_PT" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Francisco Sousa — Web Developer",
      "description": "Criação de websites rápidos e modernos para negócios em Cascais e arredores.",
      "url": "https://fsousa-dev.pages.dev",
      "telephone": "+351939021876",
      "email": "franciscobarrososousa@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cascais",
        "addressRegion": "Lisboa",
        "addressCountry": "PT"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": 38.6966,
          "longitude": -9.4215
        },
        "geoRadius": "30000"
      },
      "priceRange": "€€",
      "openingHours": "Mo-Fr 09:00-18:00",
      "sameAs": []
    })} />
  </head>
  <body class="bg-white text-[#0f172a]">

    <!-- NAVBAR -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0f172a]/95 backdrop-blur-sm border-b border-white/10">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-[#f97316] font-bold text-xl" style="font-family:'Sora',sans-serif;">FS</span>
          <span class="text-white font-semibold text-sm hidden sm:block" style="font-family:'Sora',sans-serif;">Francisco Sousa</span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="#servicos" class="text-white/80 hover:text-[#f97316] text-sm font-medium transition-colors">Serviços</a>
          <a href="#portfolio" class="text-white/80 hover:text-[#f97316] text-sm font-medium transition-colors">Portfolio</a>
          <a href="#contacto" class="text-white/80 hover:text-[#f97316] text-sm font-medium transition-colors">Contacto</a>
          <a
            href="https://wa.me/351939021876?text=Olá%2C%20gostava%20de%20pedir%20um%20orçamento%20para%20um%20website."
            target="_blank"
            rel="noopener noreferrer"
            class="bg-[#25d366] hover:bg-[#1fbe5a] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </nav>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Abrir menu"
          aria-expanded="false"
        >
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu slide-in -->
      <div
        id="mobile-menu"
        class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out bg-[#0f172a] border-t border-white/10"
      >
        <nav class="flex flex-col px-4 py-4 gap-1">
          <a href="#servicos" class="mobile-link text-white/80 hover:text-[#f97316] text-base font-medium py-3 px-2 rounded-lg hover:bg-white/5 transition-colors">Serviços</a>
          <a href="#portfolio" class="mobile-link text-white/80 hover:text-[#f97316] text-base font-medium py-3 px-2 rounded-lg hover:bg-white/5 transition-colors">Portfolio</a>
          <a href="#contacto" class="mobile-link text-white/80 hover:text-[#f97316] text-base font-medium py-3 px-2 rounded-lg hover:bg-white/5 transition-colors">Contacto</a>
          <a
            href="https://wa.me/351939021876?text=Olá%2C%20gostava%20de%20pedir%20um%20orçamento%20para%20um%20website."
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white text-base font-semibold px-4 py-3 rounded-lg transition-colors flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pedir orçamento grátis
          </a>
        </nav>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer id="contacto" class="bg-[#0f172a] text-white py-12 mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-8 border-b border-white/10">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[#f97316] font-bold text-2xl" style="font-family:'Sora',sans-serif;">FS</span>
              <span class="font-semibold text-lg" style="font-family:'Sora',sans-serif;">Francisco Sousa</span>
            </div>
            <p class="text-white/60 text-sm leading-relaxed">Websites rápidos e modernos para negócios locais. Baseado em Cascais, Portugal.</p>
          </div>
          <!-- Links -->
          <div>
            <h4 class="font-semibold text-sm uppercase tracking-wider text-white/40 mb-4">Navegação</h4>
            <ul class="space-y-2 text-sm text-white/70">
              <li><a href="#servicos" class="hover:text-[#f97316] transition-colors">Serviços</a></li>
              <li><a href="#portfolio" class="hover:text-[#f97316] transition-colors">Portfolio</a></li>
              <li><a href="#contacto" class="hover:text-[#f97316] transition-colors">Contacto</a></li>
            </ul>
          </div>
          <!-- Contact -->
          <div>
            <h4 class="font-semibold text-sm uppercase tracking-wider text-white/40 mb-4">Contacto</h4>
            <ul class="space-y-3 text-sm">
              <li>
                <a
                  href="https://wa.me/351939021876?text=Olá%2C%20gostava%20de%20pedir%20um%20orçamento%20para%20um%20website."
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 text-[#25d366] hover:text-[#1fbe5a] font-semibold transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
              </li>
              <li>
                <a href="mailto:franciscobarrososousa@gmail.com" class="flex items-center gap-2 text-white/70 hover:text-[#f97316] transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  franciscobarrososousa@gmail.com
                </a>
              </li>
              <li class="flex items-center gap-2 text-white/60">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                Cascais, Portugal
              </li>
            </ul>
          </div>
        </div>
        <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-white/40">
          <p>&copy; {new Date().getFullYear()} Francisco Sousa. Todos os direitos reservados.</p>
          <p>Feito com ❤️ em Cascais</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      btn?.addEventListener('click', () => {
        const isOpen = menu!.style.maxHeight && menu!.style.maxHeight !== '0px';
        if (isOpen) {
          menu!.style.maxHeight = '0px';
          iconOpen!.classList.remove('hidden');
          iconClose!.classList.add('hidden');
          btn!.setAttribute('aria-expanded', 'false');
        } else {
          menu!.style.maxHeight = menu!.scrollHeight + 'px';
          iconOpen!.classList.add('hidden');
          iconClose!.classList.remove('hidden');
          btn!.setAttribute('aria-expanded', 'true');
        }
      });

      // Close menu on link click
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          menu!.style.maxHeight = '0px';
          iconOpen!.classList.remove('hidden');
          iconClose!.classList.add('hidden');
          btn!.setAttribute('aria-expanded', 'false');
        });
      });
    </script>
  </body>
</html>
