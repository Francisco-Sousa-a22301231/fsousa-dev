---
import '../styles/global.css';
import { t, tArray, localeConfig, supportedLocales, getLocalizedPath, getWhatsAppLink } from '../i18n/utils';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  currentPath?: string;
}

const {
  locale = 'pt',
  currentPath = '/',
} = Astro.props;

const title = Astro.props.title || t(locale, 'meta.title');
const description = Astro.props.description || t(locale, 'meta.description');

const canonicalUrl = 'https://fsousa-dev.pages.dev';
const ogImage = `${canonicalUrl}/og-image.png`;
const ogLocale = localeConfig[locale]?.ogLocale || 'pt_PT';

const waLink = getWhatsAppLink(locale, 'whatsapp.default_message');

const faqData = tArray(locale, 'faq.items');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl + getLocalizedPath(currentPath, locale)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- hreflang alternates -->
    {supportedLocales.map((loc) => (
      <link rel="alternate" hreflang={loc} href={canonicalUrl + getLocalizedPath(currentPath, loc)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={canonicalUrl + getLocalizedPath(currentPath, 'pt')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl + getLocalizedPath(currentPath, locale)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Francisco Sousa — Web Developer",
      "description": t(locale, 'structured_data.description'),
      "url": "https://fsousa-dev.pages.dev",
      "telephone": "+351939021876",
      "email": "franciscobarrososousa@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cascais",
        "addressCountry": "PT"
      },
      "priceRange": "€€",
      "openingHours": "Mo-Fr 09:00-18:00",
      "sameAs": ["https://github.com/Francisco-Sousa-a22301231"]
    })} />

    <!-- FAQPage structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />
  </head>
  <body>

    <!-- PRELOADER -->
    <div class="preloader" id="preloader" aria-hidden="true">
      <div class="preloader-phrase" id="preloader-phrase-1">{t(locale, 'preloader.phrase1_prefix')}<span class="preloader-gradient">{t(locale, 'preloader.phrase1_highlight')}</span></div>
      <div class="preloader-phrase" id="preloader-phrase-2">{t(locale, 'preloader.phrase2_prefix')}<span class="preloader-gradient">{t(locale, 'preloader.phrase2_highlight')}</span>{t(locale, 'preloader.phrase2_suffix')}</div>
      <div class="preloader-logo" id="preloader-logo">FS</div>
      <div class="preloader-name" id="preloader-name">Francisco Sousa</div>
      <div class="preloader-bar" id="preloader-bar"></div>
    </div>

    <!-- SCROLL PROGRESS BAR -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

    <!-- GRAIN TEXTURE OVERLAY -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- CUSTOM CURSOR (desktop only) -->
    <div class="cursor-dot" id="custom-cursor" aria-hidden="true">
      <span class="cursor-dot-text">{t(locale, 'cursor.view')}</span>
    </div>

    <!-- NAVBAR -->
    <header id="main-header" class="fixed top-0 left-0 right-0 z-50 bg-transparent border-b border-transparent transition-all duration-500">
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 flex items-center justify-between h-20">
        <!-- Logo -->
        <a href={getLocalizedPath('/', locale)} class="link-underline text-[var(--color-text)] font-light text-lg tracking-tight">
          Francisco Sousa
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="#servicos" class="nav-link" data-section="servicos">{t(locale, 'nav.services')}</a>
          <a href="#processo" class="nav-link" data-section="processo">{t(locale, 'nav.process')}</a>
          <a href="#portfolio" class="nav-link" data-section="portfolio">{t(locale, 'nav.portfolio')}</a>
          <a href="#contacto" class="nav-link" data-section="contacto">{t(locale, 'nav.contact')}</a>
          <LanguageSwitcher locale={locale} currentPath={currentPath} variant="desktop" />
        </nav>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden relative z-50 w-10 h-10 flex flex-col items-center justify-center gap-1.5"
          aria-label={t(locale, 'nav.open_menu')}
          aria-expanded="false"
        >
          <span class="menu-line w-6 h-px bg-[var(--color-text)] transition-all duration-300 origin-center"></span>
          <span class="menu-line w-6 h-px bg-[var(--color-text)] transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </header>

    <!-- MOBILE MENU OVERLAY -->
    <div id="mobile-menu" class="mobile-menu-overlay">
      <nav class="flex flex-col gap-2 w-full">
        <a href="#servicos" class="mobile-nav-link">{t(locale, 'nav.services')}</a>
        <a href="#processo" class="mobile-nav-link">{t(locale, 'nav.process')}</a>
        <a href="#portfolio" class="mobile-nav-link">{t(locale, 'nav.portfolio')}</a>
        <a href="#contacto" class="mobile-nav-link">{t(locale, 'nav.contact')}</a>
      </nav>
      <div class="mt-12 space-y-3">
        <a href="tel:+351939021876" class="mobile-nav-link text-[var(--color-text-muted)]" style="font-size: 1rem; font-weight: 400;">939 021 876</a>
        <a href="mailto:franciscobarrososousa@gmail.com" class="mobile-nav-link text-[var(--color-text-muted)]" style="font-size: 1rem; font-weight: 400;">franciscobarrososousa@gmail.com</a>
      </div>
      <LanguageSwitcher locale={locale} currentPath={currentPath} variant="mobile" />
    </div>

    <!-- PAGE CONTENT -->
    <main class="relative overflow-hidden">
      <!-- Floating decorative shapes -->
      <div class="floating-shape floating-shape-1" aria-hidden="true"></div>
      <div class="floating-shape floating-shape-2" aria-hidden="true"></div>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer id="contacto" class="relative">
      <!-- Top divider -->
      <div class="section-divider"></div>

      <!-- Large CTA -->
      <div class="py-[var(--section-py)] px-6 sm:px-8">
        <div class="max-w-[1400px] mx-auto">
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-6" data-animate>
            <span class="inline-block w-8 h-px bg-[var(--color-accent)] align-middle mr-3"></span>
            {t(locale, 'footer.cta_label')}
          </p>
          <h2 class="font-light tracking-tight leading-[0.95] mb-6" style="font-size: var(--text-hero);" data-animate>
            {t(locale, 'footer.cta_title_line1')}<br/><span class="gradient-text">{t(locale, 'footer.cta_title_highlight')}</span>
          </h2>
          <div class="reveal-line mb-12"></div>

          <!-- Contact links -->
          <div class="flex flex-col sm:flex-row gap-6 sm:gap-12" data-animate>
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline text-lg font-light text-[var(--color-text)]"
              data-cursor="expand"
            >
              WhatsApp
            </a>
            <a href="mailto:franciscobarrososousa@gmail.com" class="link-underline text-lg font-light text-[var(--color-text)]" data-cursor="expand">
              franciscobarrososousa@gmail.com
            </a>
            <a href="tel:+351939021876" class="link-underline text-lg font-light text-[var(--color-text)]" data-cursor="expand">
              939 021 876
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="section-divider"></div>
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-[var(--text-xs)] text-[var(--color-text-subtle)]">
          &copy; {new Date().getFullYear()} Francisco Sousa
        </p>
        <div class="flex items-center gap-6 text-[var(--text-xs)] text-[var(--color-text-subtle)]">
          <span>{t(locale, 'footer.location')}</span>
          <span id="local-time"></span>
        </div>
      </div>
    </footer>

    <!-- Floating WhatsApp Button -->
    <a
      id="wa-float"
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-float-glow fixed bottom-6 right-6 z-50 bg-[#25d366] hover:bg-[#1fbe5a] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
      aria-label={t(locale, 'whatsapp.aria_label')}
    >
      <svg class="relative z-10" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ===== PRELOADER =====
      if (!prefersReducedMotion) {
        const preloader = document.getElementById('preloader');
        const phrase1 = document.getElementById('preloader-phrase-1');
        const phrase2 = document.getElementById('preloader-phrase-2');
        const logo = document.getElementById('preloader-logo');
        const preloaderName = document.getElementById('preloader-name');
        const preloaderBar = document.getElementById('preloader-bar');

        if (preloader && phrase1 && phrase2 && logo && preloaderName && preloaderBar) {
          document.body.style.overflow = 'hidden';

          const totalDuration = 1970;
          const barStart = performance.now();

          function animateBar(now: number) {
            const elapsed = now - barStart;
            const progress = Math.min(elapsed / totalDuration, 1);
            preloaderBar.style.width = (progress * 100) + '%';
            if (progress < 1) requestAnimationFrame(animateBar);
          }
          requestAnimationFrame(animateBar);

          setTimeout(() => { phrase1.classList.add('is-active'); }, 80);
          setTimeout(() => {
            phrase1.classList.remove('is-active');
            phrase1.classList.add('is-exiting');
          }, 580);
          setTimeout(() => { phrase2.classList.add('is-active'); }, 660);
          setTimeout(() => {
            phrase2.classList.remove('is-active');
            phrase2.classList.add('is-exiting');
          }, 1200);
          setTimeout(() => { logo.classList.add('is-active'); }, 1280);
          setTimeout(() => { preloaderName.classList.add('is-active'); }, 1420);
          setTimeout(() => {
            preloader.classList.add('is-done');
            document.body.style.overflow = '';
            document.dispatchEvent(new CustomEvent('preloader-done'));
          }, 1970);
        }
      } else {
        const preloader = document.getElementById('preloader');
        if (preloader) preloader.classList.add('is-done');
        document.dispatchEvent(new CustomEvent('preloader-done'));
      }

      // ===== SCROLL PROGRESS BAR =====
      const scrollProgress = document.getElementById('scroll-progress');
      if (scrollProgress && !prefersReducedMotion) {
        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          scrollProgress.style.width = progress + '%';
        }, { passive: true });
      }

      // ===== LENIS SMOOTH SCROLL =====
      if (!prefersReducedMotion) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 2,
        });

        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time: number) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }

      // ===== CUSTOM CURSOR =====
      if (!prefersReducedMotion && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
        const cursor = document.getElementById('custom-cursor');
        if (cursor) {
          document.body.classList.add('has-custom-cursor');

          let mouseX = 0;
          let mouseY = 0;
          let cursorX = 0;
          let cursorY = 0;

          document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
          });

          gsap.ticker.add(() => {
            const lerp = 0.15;
            cursorX += (mouseX - cursorX) * lerp;
            cursorY += (mouseY - cursorY) * lerp;
            cursor.style.left = cursorX + 'px';
            cursor.style.top = cursorY + 'px';
          });

          const interactiveElements = document.querySelectorAll('a, button, [role="button"], [data-cursor="expand"]');
          interactiveElements.forEach(el => {
            if ((el as HTMLElement).dataset.cursor === 'none' || el.closest('[data-cursor="none"]')) return;
            el.addEventListener('mouseenter', () => cursor.classList.add('is-hovering'));
            el.addEventListener('mouseleave', () => {
              cursor.classList.remove('is-hovering');
              cursor.classList.remove('is-project');
            });
          });

          const projectCards = document.querySelectorAll('[data-cursor="project"]');
          projectCards.forEach(el => {
            el.addEventListener('mouseenter', () => {
              cursor.classList.add('is-project');
              cursor.classList.add('is-hovering');
            });
            el.addEventListener('mouseleave', () => {
              cursor.classList.remove('is-project');
              cursor.classList.remove('is-hovering');
            });
          });
        }
      }

      // ===== MOBILE MENU =====
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuLines = menuBtn?.querySelectorAll('.menu-line');

      menuBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('is-open');
        if (isOpen) {
          mobileMenu?.classList.remove('is-open');
          menuBtn.setAttribute('aria-expanded', 'false');
          if (menuLines && menuLines.length >= 2) {
            (menuLines[0] as HTMLElement).style.transform = '';
            (menuLines[1] as HTMLElement).style.transform = '';
          }
        } else {
          mobileMenu?.classList.add('is-open');
          menuBtn.setAttribute('aria-expanded', 'true');
          if (menuLines && menuLines.length >= 2) {
            (menuLines[0] as HTMLElement).style.transform = 'rotate(45deg) translateY(4px)';
            (menuLines[1] as HTMLElement).style.transform = 'rotate(-45deg) translateY(-4px)';
          }
        }
      });

      document.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.remove('is-open');
          menuBtn?.setAttribute('aria-expanded', 'false');
          if (menuLines && menuLines.length >= 2) {
            (menuLines[0] as HTMLElement).style.transform = '';
            (menuLines[1] as HTMLElement).style.transform = '';
          }
        });
      });

      // ===== NAV: GLASS ON SCROLL =====
      const header = document.getElementById('main-header');
      const heroSection = document.getElementById('hero');
      if (header && heroSection) {
        const headerObserver = new IntersectionObserver(
          ([entry]) => {
            header.classList.toggle('nav-glass', !entry.isIntersecting);
          },
          { threshold: 0, rootMargin: '-80px 0px 0px 0px' }
        );
        headerObserver.observe(heroSection);
      }

      // ===== NAV: ACTIVE SECTION =====
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]');
      const sections = document.querySelectorAll<HTMLElement>('section[id]');

      if (sections.length > 0 && navLinks.length > 0) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((link) => {
                  link.classList.toggle('active', link.dataset.section === id);
                });
              }
            });
          },
          { threshold: 0.3, rootMargin: '-80px 0px -50% 0px' }
        );
        sections.forEach((section) => sectionObserver.observe(section));
      }

      // ===== GSAP SCROLL ANIMATIONS =====
      if (!prefersReducedMotion) {
        gsap.utils.toArray<HTMLElement>('.line-inner').forEach((el) => {
          const trigger = el.closest('[data-animate]') || el.closest('section') || el;
          gsap.fromTo(el,
            { y: '110%' },
            {
              y: '0%',
              duration: 1,
              ease: 'expo.out',
              scrollTrigger: {
                trigger: trigger,
                start: 'top 80%',
                once: true,
              },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('[data-animate]').forEach((el) => {
          const delay = parseFloat(el.dataset.delay || '0') * 0.1;
          gsap.fromTo(el,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 1,
              delay,
              ease: 'expo.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('[data-animate-left]').forEach((el) => {
          gsap.fromTo(el,
            { opacity: 0, x: -40 },
            {
              opacity: 1, x: 0, duration: 1, ease: 'expo.out',
              scrollTrigger: { trigger: el, start: 'top 85%', once: true },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('[data-animate-right]').forEach((el) => {
          gsap.fromTo(el,
            { opacity: 0, x: 40 },
            {
              opacity: 1, x: 0, duration: 1, ease: 'expo.out',
              scrollTrigger: { trigger: el, start: 'top 85%', once: true },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('.parallax-img').forEach((el) => {
          gsap.to(el, {
            y: '-15%',
            ease: 'none',
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1,
            },
          });
        });

        const pricingCards = document.querySelectorAll('.pricing-card');
        if (pricingCards.length > 0) {
          gsap.fromTo(pricingCards,
            { opacity: 0, y: 40 },
            {
              opacity: 1, y: 0, duration: 0.8, stagger: 0.15, ease: 'expo.out',
              scrollTrigger: { trigger: pricingCards[0], start: 'top 85%', once: true },
            }
          );
        }
      } else {
        document.querySelectorAll('[data-animate], [data-animate-left], [data-animate-right], .hero-fade').forEach((el) => {
          (el as HTMLElement).style.opacity = '1';
          (el as HTMLElement).style.transform = 'none';
        });
        document.querySelectorAll('.line-inner').forEach((el) => {
          (el as HTMLElement).style.transform = 'none';
        });
      }

      // ===== 3D TILT EFFECT ON CARDS =====
      if (!prefersReducedMotion && window.matchMedia('(pointer: fine)').matches) {
        document.querySelectorAll('.tilt-card').forEach((card) => {
          const el = card as HTMLElement;
          const shine = el.querySelector('.tilt-card-shine') as HTMLElement;

          el.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * -8;
            const rotateY = ((x - centerX) / centerX) * 8;
            el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
            if (shine) {
              shine.style.setProperty('--mouse-x', (x / rect.width * 100) + '%');
              shine.style.setProperty('--mouse-y', (y / rect.height * 100) + '%');
            }
          });

          el.addEventListener('mouseleave', () => {
            el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
          });
        });
      }

      // ===== CLIP-PATH REVEAL ON SCROLL =====
      if (!prefersReducedMotion) {
        const clipEls = document.querySelectorAll('.clip-reveal');
        const clipObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              clipObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        clipEls.forEach((el) => clipObserver.observe(el));
      } else {
        document.querySelectorAll('.clip-reveal').forEach((el) => el.classList.add('is-revealed'));
      }

      // ===== STAGGER POPUP ON SCROLL =====
      if (!prefersReducedMotion) {
        const staggerGroups = document.querySelectorAll('[data-stagger-parent]');
        staggerGroups.forEach((parent) => {
          const children = parent.querySelectorAll('.stagger-popup');
          const staggerObs = new IntersectionObserver(([entry]) => {
            if (entry.isIntersecting) {
              children.forEach((child, i) => {
                setTimeout(() => {
                  child.classList.add('is-visible');
                }, i * 120);
              });
              staggerObs.unobserve(entry.target);
            }
          }, { threshold: 0.15 });
          staggerObs.observe(parent);
        });
      } else {
        document.querySelectorAll('.stagger-popup').forEach((el) => el.classList.add('is-visible'));
      }

      // ===== SECTION TRANSITION IN =====
      if (!prefersReducedMotion) {
        const sectionTransitions = document.querySelectorAll('.section-transition-in');
        const sectionTransObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              sectionTransObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.05 });
        sectionTransitions.forEach((el) => sectionTransObs.observe(el));
      } else {
        document.querySelectorAll('.section-transition-in').forEach((el) => el.classList.add('is-visible'));
      }

      // ===== SCALE-IN ON SCROLL =====
      if (!prefersReducedMotion) {
        const scaleEls = document.querySelectorAll('.scale-in');
        const scaleObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              scaleObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });
        scaleEls.forEach((el) => scaleObs.observe(el));
      } else {
        document.querySelectorAll('.scale-in').forEach((el) => el.classList.add('is-visible'));
      }

      // ===== REVEAL LINES =====
      if (!prefersReducedMotion) {
        const revealLines = document.querySelectorAll('.reveal-line');
        const revealObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        revealLines.forEach((el) => revealObs.observe(el));
      }

      // ===== HERO ENTRANCE AFTER PRELOADER =====
      if (!prefersReducedMotion) {
        const triggerHero = () => {
          const heroFadeEls = document.querySelectorAll('.hero-fade');
          if (heroFadeEls.length > 0) {
            gsap.fromTo(heroFadeEls,
              { opacity: 0, y: 60 },
              {
                opacity: 1,
                y: 0,
                duration: 1.4,
                stagger: 0.15,
                ease: 'expo.out',
                delay: 0.1,
              }
            );
          }
        };
        document.addEventListener('preloader-done', triggerHero, { once: true });
      }

      // ===== MAGNETIC BUTTON EFFECT =====
      if (!prefersReducedMotion && window.matchMedia('(pointer: fine)').matches) {
        document.querySelectorAll('.magnetic-btn').forEach((btn) => {
          const el = btn as HTMLElement;
          const strength = 0.15;

          el.addEventListener('mousemove', (e: MouseEvent) => {
            e.stopPropagation();
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
          });

          el.addEventListener('mouseleave', () => {
            el.style.transform = 'translate(0, 0)';
          });
        });
      }

      // ===== FLOATING WHATSAPP (show after hero) =====
      const waFloat = document.getElementById('wa-float');
      const heroEl = document.getElementById('hero');
      if (waFloat && heroEl) {
        const waObserver = new IntersectionObserver(
          ([entry]) => {
            if (!entry.isIntersecting) {
              waFloat.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
              waFloat.classList.add('opacity-100', 'translate-y-0');
            } else {
              waFloat.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
              waFloat.classList.remove('opacity-100', 'translate-y-0');
            }
          },
          { threshold: 0 }
        );
        waObserver.observe(heroEl);
      }

      // ===== LOCAL TIME (footer) =====
      const timeEl = document.getElementById('local-time');
      if (timeEl) {
        const updateTime = () => {
          const now = new Date();
          const timeStr = now.toLocaleTimeString('pt-PT', {
            hour: '2-digit',
            minute: '2-digit',
            timeZone: 'Europe/Lisbon',
          });
          timeEl.textContent = timeStr + ' WET';
        };
        updateTime();
        setInterval(updateTime, 60000);
      }

      // ===== COUNTER ANIMATION =====
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.count || '0', 10);
            const prefix = el.dataset.prefix || '';
            const suffix = el.dataset.suffix || '';
            const duration = prefersReducedMotion ? 0 : 1500;
            const start = performance.now();

            if (prefersReducedMotion) {
              el.textContent = prefix + target + suffix;
              counterObserver.unobserve(el);
              return;
            }

            function animate(now: number) {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.round(eased * target);
              el.textContent = prefix + current + suffix;
              if (progress < 1) requestAnimationFrame(animate);
            }

            requestAnimationFrame(animate);
            counterObserver.unobserve(el);
          }
        });
      }, { threshold: 0.5 });

      document.querySelectorAll('[data-count]').forEach((el) => {
        counterObserver.observe(el);
      });
    </script>
  </body>
</html>
