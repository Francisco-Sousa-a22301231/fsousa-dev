---
import Layout from '../layouts/Layout.astro';
import ClientLogoBar from '../components/ClientLogoBar.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import PricingCard from '../components/PricingCard.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FaqItem from '../components/FaqItem.astro';
import GuaranteeSection from '../components/GuaranteeSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ContactForm from '../components/ContactForm.astro';

const WA_LINK = "https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20vi%20o%20seu%20site%20e%20estou%20interessado%20num%20or%C3%A7amento%20para%20o%20meu%20neg%C3%B3cio.";
const WA_LINK_PAGINA = "https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20estou%20interessado%20numa%20P%C3%A1gina%20Web%20Profissional%20para%20o%20meu%20neg%C3%B3cio.";
const WA_LINK_SITE = "https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20estou%20interessado%20num%20Website%20Completo%20para%20o%20meu%20neg%C3%B3cio.";
const WA_LINK_APP = "https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20estou%20interessado%20numa%20Aplica%C3%A7%C3%A3o%20M%C3%B3vel%20para%20o%20meu%20neg%C3%B3cio.";

const faqs = [
  { question: "Quanto custa por mês depois?", answer: "Zero. O alojamento do primeiro ano está incluído. Depois disso, o custo de alojamento é menos de €10/mês — e eu ajudo a configurar tudo. Não há mensalidades pelo meu trabalho, nunca." },
  { question: "Quanto tempo demora?", answer: "Uma página simples fica pronta em 3–5 dias úteis. Um website completo em 1–2 semanas. Uso o Método Rápido — um processo testado para entregar rápido sem sacrificar qualidade." },
  { question: "Já tenho Instagram, para quê um site?", answer: "O Instagram não aparece no Google. Quando alguém pesquisa o seu tipo de negócio, encontra quem tem site — não quem tem Instagram. Um website é o seu cartão de visita 24 horas por dia, 7 dias por semana." },
  { question: "Preciso de domínio e alojamento?", answer: "Eu trato de tudo. O custo de alojamento está incluído no primeiro ano." },
  { question: "Posso alterar o conteúdo sozinho?", answer: "Sim. Incluo um sistema simples para editar textos e imagens sem precisar de programar." },
  { question: "Posso ver exemplos antes de começar?", answer: "Sim. Antes de começar a construir, mostro-lhe um esboço do design para aprovação. Só avanço quando estiver satisfeito." },
  { question: "Trabalha remotamente?", answer: "Sim. Trabalho remotamente para qualquer parte do mundo. Reuniões por WhatsApp ou videochamada — funciona perfeitamente." },
  { question: "E se não gostar do resultado?", answer: "Mostro-lhe o progresso a cada etapa. Só paga o segundo pagamento quando estiver 100% satisfeito. Sem risco." },
  { question: "O que acontece após os 30 dias de suporte?", answer: "O seu site continua online normalmente. O alojamento custa menos de €10/mês após o primeiro ano. Se precisar de alterações ou atualizações futuras, estou disponível — basta enviar mensagem no WhatsApp." },
];
---

<Layout>
  <!-- ===== HERO ===== -->
  <section id="hero" class="relative min-h-[100vh] flex items-end pb-16 sm:pb-24 pt-32 sm:pt-40">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 w-full">
      <!-- Small label -->
      <p class="hero-fade text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-8">
        Freelance Web Developer
      </p>

      <!-- Massive headline — LIGHT weight -->
      <h1 class="hero-fade font-light tracking-tight leading-[0.95] mb-10" style="font-size: var(--text-hero);">
        Ajudo negócios<br/>
        a crescer com<br/>
        <span class="text-[var(--color-accent)]">websites que convertem</span>
      </h1>

      <!-- Description + CTA row -->
      <div class="hero-fade flex flex-col md:flex-row md:items-end md:justify-between gap-8 md:gap-16">
        <!-- Body paragraph -->
        <p class="text-[var(--color-text-muted)] text-lg md:text-xl font-light leading-relaxed max-w-lg">
          Websites profissionais a preço fixo para restaurantes, clínicas, lojas e escolas. Sem agência, sem mensalidades. Entrega em 5 dias.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-start gap-4 flex-shrink-0">
          <a
            href="#portfolio"
            class="link-pill magnetic-btn group"
            data-cursor="expand"
          >
            Ver projetos
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:translate-y-0.5"><path d="m6 9 6 6 6-6"/></svg>
          </a>
          <a
            href="#contacto-form"
            class="link-pill magnetic-btn group"
            data-cursor="expand"
          >
            Contactar
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Location tag -->
      <div class="hero-fade mt-12 pt-8 border-t border-[var(--color-border)]">
        <p class="text-[var(--text-xs)] text-[var(--color-text-subtle)] uppercase tracking-[0.15em]">
          100% Remoto · Portugal
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CLIENT CATEGORIES ===== -->
  <ClientLogoBar />

  <!-- ===== ABOUT ===== -->
  <AboutSection />

  <!-- ===== SERVICES / PRICING ===== -->
  <section id="servicos" class="relative">
    <div class="section-divider"></div>
    <div class="py-[var(--section-py)] px-6 sm:px-8">
      <div class="max-w-[1400px] mx-auto">
        <!-- Section header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
          <div>
            <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Serviços</p>
            <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
              Escolha o que o seu<br/>negócio precisa
            </h2>
          </div>
          <p class="text-[var(--color-text-muted)] text-lg font-light max-w-md" data-animate>
            Preço fixo. Sem surpresas. 50% para começar, 50% na entrega.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--color-border)] max-w-[1200px] mx-auto">
          <PricingCard
            title="Página Web"
            description="Ideal para restaurantes, cabeleireiros, clínicas e lojas."
            price="€300"
            priceMax="€600"
            priceNote="Pagamento único · Sem mensalidades"
            features={[
              "Design moderno e personalizado",
              "Adaptado ao telemóvel",
              "Formulário de contacto",
              "Integração Google Maps",
              "SEO básico",
              "Entrega em 3–5 dias úteis",
            ]}
            ctaText="Pedir orçamento"
            ctaLink={WA_LINK_PAGINA}
          />

          <PricingCard
            title="Website Completo"
            description="Ideal para empresas com vários serviços, clínicas com equipa, escolas."
            price="€800"
            priceMax="€1500"
            priceNote="Pagamento único · Sem mensalidades"
            highlighted={true}
            features={[
              "Tudo do plano anterior",
              "3–5 páginas (Home, Sobre, Serviços…)",
              "Editar conteúdo sem programar",
              "Integração redes sociais",
              "Google Analytics incluído",
              "SEO completo + Google Business",
              "Entrega em 1–2 semanas",
            ]}
            ctaText="Pedir orçamento"
            ctaLink={WA_LINK_SITE}
          />

          <PricingCard
            title="Aplicação Móvel"
            description="Ideal para negócios que precisam de app iOS e Android."
            price="€2000"
            priceNote="Sob consulta · Projeto à medida"
            features={[
              "App personalizada",
              "Funciona em iPhone e Android",
              "Painel de administração",
              "Design exclusivo",
              "Publicação nas lojas",
              "Timeline e preço sob consulta",
            ]}
            ctaText="Falar sobre o projeto"
            ctaLink={WA_LINK_APP}
          />
        </div>

        <p class="text-[var(--color-text-subtle)] text-[var(--text-small)] text-center mt-12" data-animate>
          Precisa de e-commerce ou algo diferente? <a href="#contacto-form" class="link-underline text-[var(--color-text)]">Envie uma mensagem</a> — é gratuito e sem compromisso.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <ProcessTimeline />

  <!-- ===== PORTFOLIO ===== -->
  <section id="portfolio" class="relative">
    <div class="section-divider"></div>
    <div class="py-[var(--section-py)] px-6 sm:px-8">
      <div class="max-w-[1400px] mx-auto">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
          <div>
            <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Portfolio</p>
            <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
              Resultados reais para<br/>negócios como o seu
            </h2>
          </div>
          <p class="text-[var(--color-text-muted)] text-lg font-light" data-animate>
            Projetos reais, métricas reais.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 max-w-[1100px]">
          <PortfolioCard
            tag="App educativa · App Store"
            title="My Lessons"
            description="App para iPhone e Android com gestão de aulas, pagamentos e perfil de alunos."
            result="Disponível na App Store. Performance 100/100."
            link="https://apps.apple.com/pt/app/my-lessons-gerir-explicacoes/id6743955907"
            linkText="Ver na App Store"
          />

          <PortfolioCard
            tag="Restaurante"
            title="Website com menu digital e reservas"
            description="Website moderno com menu digital, reservas online, integrado com Google Maps."
            result="PageSpeed 100/100. Primeira página do Google em 2 semanas."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON ===== -->
  <ComparisonTable />

  <!-- ===== TESTIMONIALS ===== -->
  <section class="relative">
    <div class="section-divider"></div>
    <div class="py-[var(--section-py)] px-6 sm:px-8">
      <div class="max-w-[1400px] mx-auto">
        <div class="mb-16 md:mb-24">
          <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>Testemunhos</p>
          <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
            O que dizem<br/>os clientes
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          <TestimonialCard
            quote="Não percebia nada de websites. O Francisco tratou de tudo em 5 dias."
            name="Maria"
            business="Restaurante"
          />
          <TestimonialCard
            quote="O meu site antigo não funcionava no telemóvel. Agora recebo contactos todos os dias."
            name="João"
            business="Clínica"
          />
          <TestimonialCard
            quote="Preço justo, trabalho rápido, resultado excelente."
            name="Ana"
            business="Cabeleireiro"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GUARANTEE ===== -->
  <GuaranteeSection />

  <!-- ===== FAQ ===== -->
  <section class="relative">
    <div class="section-divider"></div>
    <div class="py-[var(--section-py)] px-6 sm:px-8">
      <div class="max-w-[1400px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24">
          <!-- Left: heading -->
          <div>
            <p class="text-[var(--text-label)] font-medium uppercase tracking-[0.15em] text-[var(--color-text-subtle)] mb-4" data-animate>FAQ</p>
            <h2 class="font-light tracking-tight leading-[0.95]" style="font-size: var(--text-h1);" data-animate>
              Perguntas<br/>frequentes
            </h2>
          </div>

          <!-- Right: accordion -->
          <div class="space-y-0">
            {faqs.map((faq, i) => (
              <FaqItem question={faq.question} answer={faq.answer} number={i + 1} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <ContactForm waLink={WA_LINK} />
</Layout>
