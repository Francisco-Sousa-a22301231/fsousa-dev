---
import Layout from '../layouts/Layout.astro';

const WA_LINK = "https://wa.me/351910000000?text=Olá%2C%20gostava%20de%20pedir%20um%20orçamento%20para%20um%20website.";
---

<Layout>
  <!-- ===== HERO ===== -->
  <section class="relative bg-[#0f172a] text-white overflow-hidden min-h-[90vh] flex items-center">
    <!-- Background grid texture -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>
    <!-- Orange gradient accent -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#f97316] opacity-5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/4 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 w-full">
      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-medium px-4 py-1.5 rounded-full mb-8">
          <span class="w-2 h-2 bg-[#f97316] rounded-full animate-pulse"></span>
          Disponível para novos projetos · Cascais
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6" style="font-family:'Sora',sans-serif;">
          Websites que trazem<br/>
          <span class="text-[#f97316]">clientes.</span> Não apenas visitas.
        </h1>

        <!-- Sub-headline -->
        <p class="text-xl sm:text-2xl text-white/70 font-medium mb-10 leading-relaxed max-w-2xl">
          Crio websites rápidos e modernos para negócios em Cascais.<br class="hidden sm:block"/>
          <span class="text-white/90">Pronto em 5 dias.</span>
        </p>

        <!-- Trust proof row -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-white/50 mb-10">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Mobile-first
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            SEO incluído
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Entrega em 5 dias
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Suporte incluído
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={WA_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-95 text-white font-bold text-lg px-8 py-4 rounded-xl transition-all shadow-lg shadow-[#25d366]/25"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pedir orçamento grátis
          </a>
          <a
            href="#servicos"
            class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-white/80 hover:text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all"
          >
            Ver serviços
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-40">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
    </div>
  </section>

  <!-- ===== SOCIAL PROOF STRIP ===== -->
  <section class="bg-[#f8fafc] border-y border-slate-100 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-16 text-sm text-slate-500">
        <div class="flex items-center gap-2 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#f97316"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Carrega em menos de 2 segundos
        </div>
        <div class="flex items-center gap-2 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          Perfeito no telemóvel
        </div>
        <div class="flex items-center gap-2 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Aparece no Google
        </div>
        <div class="flex items-center gap-2 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 11.9 19.79 19.79 0 0 1 1.27 3.3 2 2 0 0 1 3.24 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.1a16 16 0 0 0 6 6l.62-.58a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 16h.72z"/></svg>
          Resposta em 24h
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="servicos" class="py-20 sm:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Serviços &amp; Preços</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a] mb-4" style="font-family:'Sora',sans-serif;">
          Escolha o que o seu negócio precisa
        </h2>
        <p class="text-slate-500 text-lg max-w-xl mx-auto">
          Preços transparentes. Sem surpresas. Sem letras pequenas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">

        <!-- Card 1: Página Web -->
        <div class="relative flex flex-col bg-white border border-slate-200 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="mb-6">
            <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f172a" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-2" style="font-family:'Sora',sans-serif;">Página Web</h3>
            <p class="text-slate-500 text-sm">Ideal para restaurantes, cabeleireiros, clínicas e pequenos negócios locais.</p>
          </div>
          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif;">€300</span>
              <span class="text-slate-400 text-sm">– €600</span>
            </div>
            <p class="text-slate-400 text-xs mt-1">Pagamento único · Sem mensalidades</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>1 página completa e moderna</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Mobile-first (perfeito no telemóvel)</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>SEO básico (aparece no Google)</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Formulário de contacto</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Entrega em 3–5 dias</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>1 mês de suporte incluído</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="w-full flex items-center justify-center gap-2 border-2 border-[#0f172a] text-[#0f172a] hover:bg-[#0f172a] hover:text-white font-semibold py-3 rounded-xl transition-all">
            Pedir orçamento
          </a>
        </div>

        <!-- Card 2: Website Completo (HIGHLIGHTED) -->
        <div class="relative flex flex-col bg-[#0f172a] text-white rounded-2xl p-8 shadow-xl md:scale-105 ring-2 ring-[#f97316]">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="bg-[#f97316] text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg">
              Mais popular
            </span>
          </div>
          <div class="mb-6 mt-2">
            <div class="w-12 h-12 bg-[#f97316]/10 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="font-family:'Sora',sans-serif;">Website Completo</h3>
            <p class="text-white/60 text-sm">Para empresas que precisam de presença online profissional e completa.</p>
          </div>
          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-extrabold" style="font-family:'Sora',sans-serif;">€800</span>
              <span class="text-white/40 text-sm">– €1500</span>
            </div>
            <p class="text-white/40 text-xs mt-1">Pagamento único · Sem mensalidades</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>3–5 páginas (Home, Sobre, Serviços…)</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>CMS para editar conteúdo</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>SEO completo (Google Analytics)</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Integração redes sociais</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Formulários + WhatsApp</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Entrega em 1–2 semanas</li>
            <li class="flex items-start gap-2.5 text-sm text-white/80"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>3 meses de suporte incluído</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="w-full flex items-center justify-center gap-2 bg-[#f97316] hover:bg-[#ea6c0a] active:scale-95 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-[#f97316]/25">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Pedir orçamento
          </a>
        </div>

        <!-- Card 3: App Móvel -->
        <div class="relative flex flex-col bg-white border border-slate-200 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="mb-6">
            <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f172a" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-2" style="font-family:'Sora',sans-serif;">App Móvel</h3>
            <p class="text-slate-500 text-sm">Para negócios que precisam de uma app iOS e Android com painel de gestão.</p>
          </div>
          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-extrabold text-[#0f172a]" style="font-family:'Sora',sans-serif;">€2000</span>
              <span class="text-slate-400 text-sm">+</span>
            </div>
            <p class="text-slate-400 text-xs mt-1">Sob consulta · Projeto à medida</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>App iOS + Android (Flutter)</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Painel de administração web</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Notificações push</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Autenticação de utilizadores</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Integração com pagamentos</li>
            <li class="flex items-start gap-2.5 text-sm text-slate-600"><svg class="flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Publicação nas lojas incluída</li>
          </ul>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="w-full flex items-center justify-center gap-2 border-2 border-[#0f172a] text-[#0f172a] hover:bg-[#0f172a] hover:text-white font-semibold py-3 rounded-xl transition-all">
            Falar sobre o projeto
          </a>
        </div>
      </div>

      <!-- Bottom CTA strip -->
