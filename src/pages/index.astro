---
import Layout from '../layouts/Layout.astro';
import HeroBrowserMockup from '../components/HeroBrowserMockup.astro';
import CredibilityBar from '../components/CredibilityBar.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import PricingCard from '../components/PricingCard.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FaqItem from '../components/FaqItem.astro';
import GuaranteeSection from '../components/GuaranteeSection.astro';
import ContactForm from '../components/ContactForm.astro';

const WA_LINK = "https://wa.me/351939021876?text=Ol%C3%A1%20Francisco%2C%20vi%20o%20seu%20site%20e%20estou%20interessado%20num%20or%C3%A7amento%20para%20o%20meu%20neg%C3%B3cio.";

const faqs = [
  { question: "Quanto custa por mês depois?", answer: "Zero. O alojamento do primeiro ano está incluído. Depois disso, o custo de alojamento é menos de €10/mês — e eu ajudo a configurar tudo. Não há mensalidades pelo meu trabalho, nunca." },
  { question: "Quanto tempo demora?", answer: "Uma página simples fica pronta em 3–5 dias úteis. Um website completo em 1–2 semanas. Uso o Método Rápido — um processo testado para entregar rápido sem sacrificar qualidade." },
  { question: "Já tenho Instagram, para quê um site?", answer: "O Instagram não aparece no Google. Quando alguém pesquisa \"clínica em Cascais\" ou \"restaurante perto de mim\", encontra quem tem site — não quem tem Instagram. Um website é o seu cartão de visita 24 horas por dia, 7 dias por semana." },
  { question: "Preciso de domínio e alojamento?", answer: "Eu trato de tudo. O custo de alojamento está incluído no primeiro ano." },
  { question: "Posso alterar o conteúdo sozinho?", answer: "Sim. Incluo um sistema simples para editar textos e imagens sem precisar de programar." },
  { question: "Posso ver exemplos antes de começar?", answer: "Sim. Antes de começar a construir, mostro-lhe um esboço do design para aprovação. Só avanço quando estiver satisfeito." },
  { question: "Trabalha só em Cascais?", answer: "Trabalho remotamente para qualquer zona de Portugal. Reuniões por WhatsApp ou videochamada — funciona perfeitamente." },
  { question: "E se não gostar do resultado?", answer: "Mostro-lhe o progresso a cada etapa. Só paga o segundo pagamento quando estiver 100% satisfeito. Sem risco." },
];
---

<Layout>
  <!-- ===== HERO ===== -->
  <section id="hero" class="relative bg-[#0f172a] text-white overflow-hidden min-h-[90vh] flex items-center">
    <!-- Background grid texture -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>
    <!-- Orange gradient accent -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#f97316] opacity-5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/4 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-medium px-4 py-1.5 rounded-full mb-8">
            <span class="w-2 h-2 bg-[#f97316] rounded-full animate-pulse"></span>
            Disponível para novos projetos · Cascais
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6" style="font-family:'Sora',sans-serif;">
            O seu negócio encontrado no Google<br/>
            <span class="text-[#f97316]">em 5 dias.</span>
          </h1>

          <!-- Sub-headline -->
          <p class="text-xl sm:text-2xl text-white/70 font-medium mb-10 leading-relaxed max-w-2xl">
            Um developer, não uma agência.<br class="hidden sm:block"/>
            <span class="text-white/90">Preço fixo, sem mensalidades, sem surpresas.</span>
          </p>

          <!-- Trust proof row -->
          <div class="grid grid-cols-2 gap-3 sm:flex sm:flex-wrap sm:gap-6 text-sm text-white/50 mb-10">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              100/100 PageSpeed
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              SEO desde o dia 1
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              3–5 dias, não semanas
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              30 dias de suporte grátis
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={WA_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-[#25d366] hover:bg-[#1fbe5a] active:scale-95 text-white font-bold text-lg px-8 py-4 rounded-xl transition-all shadow-lg shadow-[#25d366]/25 hover:-translate-y-0.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Pedir orçamento grátis
            </a>
            <a
              href="#servicos"
              class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-white/80 hover:text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all"
            >
              Ver serviços
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </a>
          </div>
        </div>

        <!-- Hero visual: browser + phone mockup -->
        <HeroBrowserMockup />
      </div>
    </div>
  </section>

  <!-- ===== CREDIBILITY BAR ===== -->
  <CredibilityBar />

  <!-- ===== EU VS AGENCIA ===== -->
  <ComparisonTable waLink={WA_LINK} />

  <!-- ===== SERVICES / PRICING ===== -->
  <section id="servicos" data-animate class="py-20 sm:py-28 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 text-[#f97316] text-sm font-bold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">
          Método Rápido
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a] mb-4" style="font-family:'Sora',sans-serif;">
          Escolha o que o seu negócio precisa
        </h2>
        <p class="text-slate-500 text-lg max-w-xl mx-auto">
          Preços transparentes. Sem surpresas. 50% para começar, 50% na entrega.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto items-stretch">
        <PricingCard
          title="Página Web Profissional"
          description="Ideal para restaurantes, cabeleireiros, clínicas e lojas."
          price="€300"
          priceMax="€600"
          priceNote="Pagamento único · Sem mensalidades"
          features={[
            "Design moderno e personalizado",
            "Adaptado ao telemóvel",
            "Formulário de contacto",
            "Integração Google Maps",
            "SEO básico",
            "Entrega em 3–5 dias úteis",
          ]}
          ctaText="Quero um orçamento"
          ctaLink={WA_LINK}
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0f172a" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>'
        />

        <PricingCard
          title="Website Completo"
          description="Ideal para empresas com vários serviços, clínicas com equipa, escolas."
          price="€800"
          priceMax="€1500"
          priceNote="Pagamento único · Sem mensalidades"
          highlighted={true}
          features={[
            "Tudo do plano anterior",
            "3–5 páginas (Home, Sobre, Serviços…)",
            "Editar conteúdo sem programar",
            "Integração redes sociais",
            "Google Analytics incluído",
            "SEO completo + Google Business",
            "Entrega em 1–2 semanas",
          ]}
          ctaText="Quero um orçamento"
          ctaLink={WA_LINK}
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>'
        />
      </div>

      <!-- Bottom CTA strip -->
      <div class="mt-12 bg-[#f8fafc] border border-slate-100 rounded-2xl p-6 sm:p-8 text-center">
        <p class="text-slate-600 text-base mb-2">Precisa de app móvel, e-commerce, ou algo diferente?</p>
        <p class="font-semibold text-[#0f172a] mb-4">Envie uma mensagem — é gratuito e sem compromisso.</p>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white font-bold px-8 py-3.5 rounded-xl transition-all shadow-md shadow-[#25d366]/20 active:scale-95 hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar no WhatsApp agora
        </a>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS TIMELINE ===== -->
  <ProcessTimeline />

  <!-- ===== PORTFOLIO ===== -->
  <section id="portfolio" data-animate class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Portfolio</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a] mb-4" style="font-family:'Sora',sans-serif;">
        Resultados reais para negócios como o seu
      </h2>
      <p class="text-slate-500 text-lg mb-12">Projetos reais, métricas reais.</p>

      <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 text-left pb-4 sm:grid sm:grid-cols-2 sm:overflow-visible lg:grid-cols-2 max-w-3xl mx-auto">
        <PortfolioCard
          gradientFrom="#0f172a"
          gradientTo="#1e3a5f"
          iconSvg='<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>'
          appName="My Lessons"
          tag="App educativa na App Store"
          title="My Lessons"
          problem="Professores de aulas particulares não tinham forma de gerir alunos e pagamentos."
          solution="App para iPhone e Android com gestão de aulas, pagamentos e perfil de alunos."
          result="Disponível na App Store. Utilizada por professores em Portugal. Performance 100/100."
          link="https://apps.apple.com/pt/app/my-lessons-gerir-explicacoes/id6743955907"
          linkText="Ver na App Store"
        />

        <PortfolioCard
          gradientFrom="#7c2d12"
          gradientTo="#c2410c"
          iconSvg='<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>'
          appName="Restaurante"
          tag="Restaurante"
          title="Website com menu digital e reservas"
          problem="Restaurante sem presença online, perdia clientes para a concorrência no Google."
          solution="Website moderno com menu digital, reservas online, integrado com Google Maps."
          result="PageSpeed 100/100. Primeira página do Google em 2 semanas para a zona."
        />
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section data-animate class="py-20 bg-[#f8fafc]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">Testemunhos</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a]">
          O que dizem os clientes
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <TestimonialCard
          quote="Não percebia nada de websites. O Francisco tratou de tudo em 5 dias."
          name="Maria"
          business="Restaurante, Cascais"
          initial="M"
        />
        <TestimonialCard
          quote="O meu site antigo não funcionava no telemóvel. Agora recebo contactos todos os dias."
          name="João"
          business="Clínica, Estoril"
          initial="J"
        />
        <TestimonialCard
          quote="Preço justo, trabalho rápido, resultado excelente."
          name="Ana"
          business="Cabeleireiro, Parede"
          initial="A"
        />
      </div>
    </div>
  </section>

  <!-- ===== GUARANTEE ===== -->
  <GuaranteeSection />

  <!-- ===== FAQ ===== -->
  <section data-animate class="py-20 bg-[#f8fafc]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-[#f97316] font-semibold text-sm uppercase tracking-widest mb-3">FAQ</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#0f172a]">
          Perguntas frequentes
        </h2>
      </div>
      <div class="space-y-4">
        {faqs.map(faq => (
          <FaqItem question={faq.question} answer={faq.answer} />
        ))}
      </div>

      <!-- FAQ bottom CTA -->
      <div class="mt-10 text-center">
        <p class="text-slate-500 mb-4">Tem outra pergunta?</p>
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1fbe5a] text-white font-bold px-6 py-3 rounded-xl transition-all shadow-md shadow-[#25d366]/20 active:scale-95 hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Perguntar no WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <ContactForm waLink={WA_LINK} />
</Layout>
